# ==========================================
# BUILD STAGE
# ==========================================
FROM node:20-slim AS builder

WORKDIR /build

# Copy workspaces configurations
COPY package.json ./
COPY apps/frontend/package.json ./apps/frontend/

# Install dependencies using root cache
RUN npm install --workspace=apps/frontend

# Copy frontend source files
COPY apps/frontend/ ./apps/frontend/

# Build assets
RUN npm run build --workspace=apps/frontend

# ==========================================
# RUNTIME STAGE
# ==========================================
FROM nginx:alpine

# Copy compiled static assets
COPY --from=builder /build/apps/frontend/dist /usr/share/nginx/html

# Apply Nginx server routing configurations
COPY docker/nginx.frontend.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
