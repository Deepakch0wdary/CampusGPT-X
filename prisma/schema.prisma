  exam             Exam             @relation(fields: [examId], references: [id], onDelete: Cascade)
  qrCodeUrl        String?
  examCenter       String
  seatNumber       String?
  createdAt        DateTime         @default(now())
  seatAllocations  SeatAllocation[]
}

model SeatAllocation {
  id           String     @id @default(uuid())
  hallTicketId String
  hallTicket   HallTicket @relation(fields: [hallTicketId], references: [id], onDelete: Cascade)
  blockName    String
  roomNumber   String
  benchNumber  Int
  seatNumber   String
  createdAt    DateTime   @default(now())

  @@unique([blockName, roomNumber, benchNumber, seatNumber])
}

model QuestionPaper {
  id           String   @id @default(uuid())
  examId       String
  exam         Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  fileUrl      String
  fileName     String
  version      Int      @default(1)
  status       String   @default("PENDING") // PENDING, APPROVED, REJECTED
  approvedById String?
  approvedBy   User?    @relation(name: "QuestionPaperApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
}

model ExamAudit {
  id        String   @id @default(uuid())
  examId    String?
  exam      Exam?    @relation(fields: [examId], references: [id], onDelete: SetNull)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String   // CREATE_EXAM, UPDATE_EXAM, SCHEDULE_EXAM, DOWNLOAD_HALL_TICKET, UPLOAD_QUESTION_PAPER, APPROVE_QUESTION_PAPER
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
}

model Result {
  id             String         @id @default(uuid())
  studentId      String
  student        User           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  academicYearId String
  academicYear   AcademicYear   @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  semesterNumber Int
  sgpa           Float          @default(0.0)
  cgpa           Float          @default(0.0)
  totalMarks     Float          @default(0.0)
  percentage     Float          @default(0.0)
  creditsEarned  Int            @default(0)
  status         String         @default("DRAFT") // DRAFT, DEPT_REVIEW, EXAM_CELL_APPROVED, PUBLISHED, ARCHIVED, ROLLBACK
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  details        ResultDetail[]

