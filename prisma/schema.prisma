  bookId    String
  book      Book                   @relation(fields: [bookId], references: [id])
  quantity  Int
  unitPrice Decimal                @db.Decimal(10, 2)
  createdAt DateTime               @default(now())

  @@index([requestId])
  @@index([bookId])
}

model InventoryAudit {
