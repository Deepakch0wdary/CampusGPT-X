  bedId          String
  bed            HostelBed              @relation(fields: [bedId], references: [id])
  allocatedBy    String
  allocator      User                   @relation("WardenAllocations", fields: [allocatedBy], references: [id])
  allocatedAt    DateTime               @default(now())
  startDate      DateTime
  expectedEndDate DateTime
  actualEndDate  DateTime?
  status         String                 @default("ACTIVE") // RESERVED, ACTIVE, TRANSFERRED, COMPLETED, CANCELLED
  checkIns       HostelCheckIn[]
  checkOuts      HostelCheckOut[]
  leaves         HostelLeaveRequest[]
  fines          HostelFine[]
}

model HostelCheckIn {
  id             String           @id @default(uuid())
  allocationId   String
  allocation     HostelAllocation @relation(fields: [allocationId], references: [id], onDelete: Cascade)
  checkedInAt    DateTime         @default(now())
  checkedInBy    String
  inventoryNotes String?          @db.Text
  conditionNotes String?          @db.Text
  acknowledgement Boolean         @default(false)
}

model HostelCheckOut {
  id             String           @id @default(uuid())
  allocationId   String
  allocation     HostelAllocation @relation(fields: [allocationId], references: [id], onDelete: Cascade)
  checkedOutAt   DateTime         @default(now())
  checkedOutBy   String
  damageNotes    String?          @db.Text
  damageCost     Decimal          @default(0.0)
  inventoryNotes String?          @db.Text
  status         String           @default("COMPLETED") // COMPLETED, PENALIZED
}

model HostelTransferRequest {
  id                  String   @id @default(uuid())
  studentId           String
  currentAllocationId String
  preferredBedId      String
  reason              String   @db.Text
  status              String   @default("PENDING") // PENDING, APPROVED, REJECTED, COMPLETED, CANCELLED
  reviewedBy          String?
  reviewedAt          DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model HostelWardenAssignment {
  id             String   @id @default(uuid())
  wardenId       String
  warden         User     @relation("WardenAssignments", fields: [wardenId], references: [id], onDelete: Cascade)
