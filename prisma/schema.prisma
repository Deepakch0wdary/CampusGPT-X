  email                 String
  phone                 String
  dateOfBirth           DateTime
  gender                String
  nationality           String
  category              String
  quota                 String
  entranceExam          String?
  entranceScore         Float?
  previousInstitution   String?
  previousQualification String?
  previousPercentage    Float?
