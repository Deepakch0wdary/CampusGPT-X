  costPerMonth Decimal
  foodType     String             // VEG, NON_VEG, MIXED, CUSTOM
  active       Boolean            @default(true)
  subscriptions MessSubscription[]
  attendances   MessAttendance[]
}

model MessSubscription {
  id        String   @id @default(uuid())
  studentId String
  student   User     @relation("StudentSubscriptions", fields: [studentId], references: [id], onDelete: Cascade)
  planId    String
  plan      MessPlan @relation(fields: [planId], references: [id])
  startDate DateTime
  endDate   DateTime
  status    String   @default("ACTIVE") // ACTIVE, SUSPENDED, EXPIRED
}

model MessMenu {
  id          String   @id @default(uuid())
  planId      String
  dayOfWeek   String
  mealType    String   // BREAKFAST, LUNCH, SNACK, DINNER
  menuDetails String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MessAttendance {
  id              String   @id @default(uuid())
  studentId       String
  student         User     @relation("StudentMessAttendance", fields: [studentId], references: [id], onDelete: Cascade)
  planId          String
  plan            MessPlan @relation(fields: [planId], references: [id])
  mealDate        DateTime
  mealType        String   // BREAKFAST, LUNCH, SNACK, DINNER
  status          String   @default("PRESENT") // PRESENT, ABSENT
  qrCodeScanned   Boolean  @default(false)
}

model HostelFine {
  id           String            @id @default(uuid())
  studentId    String
  student      User              @relation("StudentFines", fields: [studentId], references: [id], onDelete: Cascade)
  allocationId String?
  allocation   HostelAllocation? @relation(fields: [allocationId], references: [id])
  fineType     String            // DAMAGE, LATE_RETURN, RULE_VIOLATION, LOST_PROPERTY, OTHER
  amount       Decimal
  reason       String
  status       String            @default("PENDING") // PENDING, PAID, WAIVED, CANCELLED
  assessedAt   DateTime          @default(now())
  paidAt       DateTime?
  waivedAt     DateTime?
  waivedBy     String?
  waiverUser   User?             @relation("WardenWaivedFines", fields: [waivedBy], references: [id])
  waiverReason String?           @db.Text
}

model HostelIncident {
  id          String   @id @default(uuid())
  hostelId    String
  hostel      Hostel   @relation(fields: [hostelId], references: [id], onDelete: Cascade)
  reporterId  String
  reporter    User     @relation("ReporterIncidents", fields: [reporterId], references: [id])
  title       String
  description String   @db.Text
  severity    String   // LOW, MEDIUM, HIGH, CRITICAL
  reportedAt  DateTime @default(now())
  actionTaken String?  @db.Text
  status      String   @default("OPEN") // OPEN, INVESTIGATING, RESOLVED, CLOSED
}

model HostelAudit {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  details   String?  @db.Text
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model TransportVehicle {
  id                   String                       @id @default(uuid())
  registrationNumber   String                       @unique
  vehicleCode          String                       @unique
  vehicleType          String                       // BUS, MINI_BUS, VAN, CAR, SHUTTLE, ELECTRIC_BUS
  manufacturer         String
  model                String
  manufactureYear      Int
  seatingCapacity      Int
  standingCapacity     Int
  fuelType             String                       // DIESEL, PETROL, CNG, ELECTRIC, HYBRID
  chassisNumberMasked  String
  engineNumberMasked   String
  insuranceExpiry      DateTime
  fitnessExpiry        DateTime
  pollutionExpiry      DateTime
  permitExpiry         DateTime
  gpsDeviceId          String                       @unique
  status               String                       @default("ACTIVE") // ACTIVE, INACTIVE, MAINTENANCE, BREAKDOWN, RETIRED
  active               Boolean                      @default(true)
  createdAt            DateTime                     @default(now())
  updatedAt            DateTime                     @updatedAt
  assignments          TransportVehicleAssignment[]
  seats                TransportSeat[]
  trips                TransportTrip[]
  locations            TransportVehicleLocation[]
  maintenances         TransportMaintenance[]
  fuelLogs             TransportFuelLog[]
  incidents            TransportIncident[]
}

model TransportDriverProfile {
  id                   String                       @id @default(uuid())
  userId               String                       @unique
  user                 User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  employeeCode         String                       @unique
  licenseNumberMasked  String
  licenseType          String
  licenseExpiry        DateTime
  emergencyContact     String
  joiningDate          DateTime
  status               String                       @default("ACTIVE") // ACTIVE, INACTIVE, ON_LEAVE
  assignments          TransportVehicleAssignment[] @relation("DriverAssignments")
  trips                TransportTrip[]              @relation("DriverTrips")
  createdAt            DateTime                     @default(now())
  updatedAt            DateTime                     @updatedAt
}

model TransportStaffProfile {
  id                   String                       @id @default(uuid())
  userId               String                       @unique
  user                 User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  employeeCode         String                       @unique
  status               String                       @default("ACTIVE") // ACTIVE, INACTIVE
  emergencyContact     String
  assignments          TransportVehicleAssignment[] @relation("ConductorAssignments")
  trips                TransportTrip[]              @relation("ConductorTrips")
  createdAt            DateTime                     @default(now())
  updatedAt            DateTime                     @updatedAt
}

model TransportRoute {
  id                       String                       @id @default(uuid())
  name                     String
  code                     String                       @unique
  description              String?                      @db.Text
  origin                   String
  destination              String
  estimatedDistanceKm      Decimal
  estimatedDurationMinutes Int
  status                   String                       @default("ACTIVE") // ACTIVE, INACTIVE, SUSPENDED
  active                   Boolean                      @default(true)
  createdAt                DateTime                     @default(now())
  updatedAt                DateTime                     @updatedAt
  stops                    TransportRouteStop[]
  assignments              TransportVehicleAssignment[]
  applications             TransportApplication[]
  subscriptions            TransportSubscription[]
  trips                    TransportTrip[]
}

model TransportStop {
  id                  String               @id @default(uuid())
  name                String
  code                String               @unique
  address             String?              @db.Text
  latitude            Float
  longitude           Float
  landmark            String?
  active              Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  routes              TransportRouteStop[]
  applicationsPickup  TransportApplication[] @relation("PickupStop")
  applicationsDrop    TransportApplication[] @relation("DropStop")
  subscriptionsPickup TransportSubscription[] @relation("SubPickupStop")
  subscriptionsDrop   TransportSubscription[] @relation("SubDropStop")
  boardings           TransportBoarding[]
}

model TransportRouteStop {
  id                   String         @id @default(uuid())
  routeId              String
  route                TransportRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)
  stopId               String
  stop                 TransportStop  @relation(fields: [stopId], references: [id], onDelete: Cascade)
  stopOrder            Int
  scheduledArrivalTime   String
  scheduledDepartureTime String
  pickupAllowed        Boolean        @default(true)
  dropAllowed          Boolean        @default(true)
  distanceFromOriginKm Decimal
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@unique([routeId, stopId])
  @@unique([routeId, stopOrder])
}

model TransportVehicleAssignment {
  id          String                @id @default(uuid())
  vehicleId   String
  vehicle     TransportVehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  routeId     String
  route       TransportRoute        @relation(fields: [routeId], references: [id], onDelete: Cascade)
  driverId    String
  driver      TransportDriverProfile @relation("DriverAssignments", fields: [driverId], references: [id], onDelete: Cascade)
  conductorId String?
  conductor   TransportStaffProfile? @relation("ConductorAssignments", fields: [conductorId], references: [id], onDelete: SetNull)
  startDate   DateTime
  endDate     DateTime?
  shift       String                // MORNING, EVENING, FULL_DAY, CUSTOM
  status      String                @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
}

model TransportApplication {
  id              String         @id @default(uuid())
  applicantUserId String
  applicant       User           @relation("ApplicantApplications", fields: [applicantUserId], references: [id], onDelete: Cascade)
  academicYearId  String
  routeId         String
  route           TransportRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)
  pickupStopId    String
  pickupStop      TransportStop  @relation("PickupStop", fields: [pickupStopId], references: [id], onDelete: Cascade)
  dropStopId      String
  dropStop        TransportStop  @relation("DropStop", fields: [dropStopId], references: [id], onDelete: Cascade)
  reason          String?        @db.Text
  status          String         @default("SUBMITTED") // DRAFT, SUBMITTED, UNDER_REVIEW, APPROVED, REJECTED, WAITLISTED, ALLOCATED, CANCELLED
  submittedAt     DateTime       @default(now())
  reviewedAt      DateTime?
  reviewedBy      String?
  reviewer        User?          @relation("TransportManagerReviewed", fields: [reviewedBy], references: [id])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model TransportSubscription {
  id           String                   @id @default(uuid())
  userId       String
  user         User                     @relation("UserSubscriptions", fields: [userId], references: [id], onDelete: Cascade)
  routeId      String
  route        TransportRoute           @relation(fields: [routeId], references: [id], onDelete: Cascade)
  pickupStopId String
  pickupStop   TransportStop            @relation("SubPickupStop", fields: [pickupStopId], references: [id], onDelete: Cascade)
  dropStopId   String
  dropStop     TransportStop            @relation("SubDropStop", fields: [dropStopId], references: [id], onDelete: Cascade)
  startDate    DateTime
  endDate      DateTime
  status       String                   @default("ACTIVE") // PENDING, ACTIVE, SUSPENDED, EXPIRED, CANCELLED
  approvedBy   String?
  approver     User?                    @relation("ManagerApprovedSubscriptions", fields: [approvedBy], references: [id])
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  allocations  TransportSeatAllocation[]
  passes       TransportPass[]
}

model TransportSeat {
  id              String                  @id @default(uuid())
  vehicleId       String
  vehicle         TransportVehicle        @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  seatNumber      String
  seatType        String                  @default("REGULAR") // REGULAR, PRIORITY, ACCESSIBLE, STAFF
  status          String                  @default("AVAILABLE") // AVAILABLE, ALLOCATED, BLOCKED, MAINTENANCE
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  allocations     TransportSeatAllocation[]

  @@unique([vehicleId, seatNumber])
}

model TransportSeatAllocation {
  id             String                @id @default(uuid())
  subscriptionId String
  subscription   TransportSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  seatId         String
  seat           TransportSeat         @relation(fields: [seatId], references: [id], onDelete: Cascade)
  allocatedBy    String
  allocator      User                  @relation("AllocatedByUser", fields: [allocatedBy], references: [id])
  allocatedAt    DateTime              @default(now())
  startDate      DateTime
  endDate        DateTime
  status         String                @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
}

model TransportPass {
  id             String                @id @default(uuid())
  subscriptionId String
  subscription   TransportSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  passNumber     String                @unique
  tokenHash      String                @unique
  issuedAt       DateTime              @default(now())
  expiresAt      DateTime
  status         String                @default("ACTIVE") // ACTIVE, EXPIRED, REVOKED, SUSPENDED
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  userId         String
  user           User                  @relation("UserPasses", fields: [userId], references: [id], onDelete: Cascade)
}

model TransportTrip {
  id                String                 @id @default(uuid())
  routeId           String
  route             TransportRoute         @relation(fields: [routeId], references: [id], onDelete: Cascade)
  vehicleId         String
  vehicle           TransportVehicle       @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  driverId          String
  driver            TransportDriverProfile @relation("DriverTrips", fields: [driverId], references: [id], onDelete: Cascade)
  conductorId       String?
  conductor         TransportStaffProfile? @relation("ConductorTrips", fields: [conductorId], references: [id], onDelete: SetNull)
  scheduledStartAt  DateTime
  actualStartAt     DateTime?
  scheduledEndAt    DateTime
  actualEndAt       DateTime?
  status            String                 @default("SCHEDULED") // SCHEDULED, BOARDING, IN_PROGRESS, DELAYED, COMPLETED, CANCELLED, BREAKDOWN
  delayMinutes      Int                    @default(0)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  boardings         TransportBoarding[]
  locations         TransportVehicleLocation[]
  delays            TransportDelay[]
  incidents         TransportIncident[]
}

model TransportBoarding {
  id           String        @id @default(uuid())
  tripId       String
  trip         TransportTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  userId       String
  user         User          @relation("BoardedUser", fields: [userId], references: [id], onDelete: Cascade)
  stopId       String
  stop         TransportStop @relation(fields: [stopId], references: [id], onDelete: Cascade)
  boardingType String        // PICKUP, DROP
  boardedAt    DateTime      @default(now())
  verifiedBy   String?
  verifier     User?         @relation("BoardingVerifier", fields: [verifiedBy], references: [id])
  status       String        @default("VERIFIED") // VERIFIED, FLAGGED
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model TransportVehicleLocation {
  id        String         @id @default(uuid())
  vehicleId String
  vehicle   TransportVehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  tripId    String?
  trip      TransportTrip? @relation(fields: [tripId], references: [id], onDelete: Cascade)
  latitude  Float
  longitude Float
  speedKph  Float
  heading   Float
  recordedAt DateTime      @default(now())
  source    String         // GPS_DEVICE, DRIVER_APP, SIMULATOR, MANUAL
}

model TransportMaintenance {
  id              String           @id @default(uuid())
  vehicleId       String
  vehicle         TransportVehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  maintenanceType String           // PREVENTIVE, CORRECTIVE, BREAKDOWN, INSPECTION, SERVICE
  description     String           @db.Text
  scheduledDate   DateTime
  startedAt       DateTime?
  completedAt     DateTime?
  odometerKm      Int
  estimatedCost   Decimal
  actualCost      Decimal
  vendorName      String
  status          String           @default("SCHEDULED") // SCHEDULED, IN_PROGRESS, COMPLETED, CANCELLED
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model TransportFuelLog {
  id            String           @id @default(uuid())
  vehicleId     String
  vehicle       TransportVehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  filledAt      DateTime
  quantityLitres Decimal
  unitPrice     Decimal
  totalAmount   Decimal
  odometerKm    Int
  fuelStation   String
  recordedBy    String
  recorder      User             @relation("FuelRecorder", fields: [recordedBy], references: [id])
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model TransportIncident {
  id          String            @id @default(uuid())
  tripId      String?
  trip        TransportTrip?    @relation(fields: [tripId], references: [id], onDelete: Cascade)
  vehicleId   String
  vehicle     TransportVehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  reportedBy  String
  reporter    User              @relation("ReporterIncidents", fields: [reportedBy], references: [id])
  type        String            // ACCIDENT, BREAKDOWN, DELAY, MEDICAL, SECURITY, BEHAVIOR, OTHER
  severity    String            // LOW, MEDIUM, HIGH, CRITICAL
  description String            @db.Text
  locationText String
  latitude    Float?
  longitude   Float?
  occurredAt  DateTime
  status      String            @default("OPEN") // OPEN, INVESTIGATING, RESOLVED, CLOSED
  resolution  String?           @db.Text
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model TransportDelay {
  id         String        @id @default(uuid())
  tripId     String
  trip       TransportTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  delayMinutes Int
  reason     String        @db.Text
  reportedAt DateTime      @default(now())
  notified   Boolean       @default(false)
}

model TransportAudit {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  details   String?  @db.Text
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Notification {
  id           String   @id @default(uuid())
  recipientId  String
  recipient    User     @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  senderId     String?
  sender       User?    @relation("NotificationSender", fields: [senderId], references: [id], onDelete: SetNull)
  title        String
  body         String   @db.Text
  type         String   // INFO, WARNING, SUCCESS, ERROR
  priority     String   // LOW, MEDIUM, HIGH, CRITICAL
  channel      String   // IN_APP, EMAIL, SMS, PUSH
  status       String   // PENDING, DELIVERED, FAILED, READ
  entityType   String?
  entityId     String?
  actionUrl    String?
  readAt       DateTime?
  deliveredAt  DateTime?
  expiresAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deliveries   NotificationDelivery[]
  readReceipts NotificationReadReceipt[]

  @@index([recipientId])
  @@index([senderId])
  @@index([createdAt])
}

model NotificationPreference {
  id                 String   @id @default(uuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  inAppEnabled       Boolean  @default(true)
  emailEnabled       Boolean  @default(true)
  smsEnabled         Boolean  @default(true)
  pushEnabled        Boolean  @default(true)
  academicEnabled    Boolean  @default(true)
  attendanceEnabled  Boolean  @default(true)
  feeEnabled         Boolean  @default(true)
  examEnabled        Boolean  @default(true)
  resultEnabled      Boolean  @default(true)
  transportEnabled   Boolean  @default(true)
  hostelEnabled      Boolean  @default(true)
  libraryEnabled     Boolean  @default(true)
  emergencyEnabled   Boolean  @default(true)
  quietHoursEnabled  Boolean  @default(false)
  quietHoursStart    String?  // HH:MM format
  quietHoursEnd      String?  // HH:MM format
  timezone           String   @default("UTC")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Announcement {
  id           String   @id @default(uuid())
  title        String
  body         String   @db.Text
  authorId     String
  author       User     @relation("AnnouncementAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  audienceType String   // ALL, ROLE, DEPARTMENT, SECTION, PROGRAM, INDIVIDUAL
  priority     String   // LOW, MEDIUM, HIGH, EMERGENCY
  publishAt    DateTime @default(now())
  expiresAt    DateTime?
  status       String   // DRAFT, PUBLISHED, ARCHIVED
  pinned       Boolean  @default(false)
  departmentId String?
  sectionId    String?
  programId    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([authorId])
  @@index([publishAt])
}

model NotificationTemplate {
  id              String   @id @default(uuid())
  name            String
  code            String   @unique
  subjectTemplate String
  bodyTemplate    String   @db.Text
  channel         String   // IN_APP, EMAIL, SMS, PUSH
  category        String   // ACADEMIC, ATTENDANCE, FEES, EXAMS, RESULTS, TRANSPORT, HOSTEL, LIBRARY, EMERGENCY, GENERAL
  active          Boolean  @default(true)
  createdById     String
  creator         User     @relation("TemplateCreator", fields: [createdById], references: [id], onDelete: Cascade)
  version         Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([createdById])
}

model NotificationDelivery {
  id                String       @id @default(uuid())
  notificationId    String
  notification      Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  channel           String       // IN_APP, EMAIL, SMS, PUSH
  provider          String       // SIMULATED_DEMO_PROVIDER
  providerMessageId String?
  attemptNumber     Int          @default(1)
  status            String       // PENDING, SENT, FAILED
  attemptedAt       DateTime     @default(now())
  deliveredAt       DateTime?
  failureReason     String?      @db.Text

  @@index([notificationId])
}

model NotificationReadReceipt {
  id             String       @id @default(uuid())
  notificationId String
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  readAt         DateTime     @default(now())
  deviceInfo     String?

  @@unique([notificationId, userId])
  @@index([notificationId])
  @@index([userId])
}

model BroadcastCampaign {
  id              String   @id @default(uuid())
  name            String
  title           String
  body            String   @db.Text
  createdById     String
  creator         User     @relation("CampaignCreator", fields: [createdById], references: [id], onDelete: Cascade)
  audienceType    String   // ALL, ROLE, DEPARTMENT, SECTION, PROGRAM
  scheduledAt     DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  status          String   // DRAFT, SCHEDULED, SENDING, COMPLETED, CANCELLED
  totalRecipients Int      @default(0)
  successCount    Int      @default(0)
  failureCount    Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  recipients      BroadcastRecipient[]

  @@index([createdById])
}

model BroadcastRecipient {
  id             String            @id @default(uuid())
  campaignId     String
  campaign       BroadcastCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  userId         String
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  notificationId String?
  deliveryStatus String            // PENDING, SENT, FAILED

  @@unique([campaignId, userId])
  @@index([campaignId])
  @@index([userId])
}

model EmergencyAlert {
  id             String   @id @default(uuid())
  title          String
  message        String   @db.Text
  severity       String   // MEDIUM, HIGH, CRITICAL
  createdById    String
  creator         User     @relation("EmergencyAlertCreator", fields: [createdById], references: [id], onDelete: Cascade)
  status         String   // ACTIVE, RESOLVED
  activatedAt    DateTime @default(now())
  resolvedAt     DateTime?
  targetAudience String   // ALL, STAFF, STUDENTS
  locationText   String?
  instructions   String?  @db.Text

  @@index([createdById])
}

model CommunicationAudit {
  id         String   @id @default(uuid())
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action     String
  entityType String
  entityId   String
  metadata   String?  @db.Text
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([createdAt])
}
