  startedAt   DateTime
  endedAt     DateTime?
  items       InventoryAuditItem[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([branchId])
  @@index([conductedBy])
}

model InventoryAuditItem {
  id               String         @id @default(uuid())
