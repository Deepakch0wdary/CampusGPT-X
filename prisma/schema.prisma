datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DISABLED
  PENDING
}

model User {
  id                  String           @id @default(uuid())
  email               String           @unique
  username            String           @unique
  passwordHash        String
  name                String
  roleId              String
  role                Role             @relation(fields: [roleId], references: [id])
  departmentId        String?
  department          Department?      @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  sectionId           String?
  section             Section?         @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  profile             UserProfile?
  status              UserStatus       @default(ACTIVE)
  isSuspended         Boolean          @default(false)
  isDisabled          Boolean          @default(false)
  mustChangePassword  Boolean          @default(true)
  failedLoginAttempts Int              @default(0)
  lockedUntil         DateTime?
  verified            Boolean          @default(false)
  userPermissions     UserPermission[]
  sessions            UserSession[]
  refreshTokens       RefreshToken[]
  loginHistories      LoginHistory[]
  auditLogs           AuditLog[]
  facultyAssignments  FacultyAssignment[]
  advisedSections     Section[]        @relation(name: "FacultyAdvisor")
  attendanceSummaries StudentAttendanceSummary[]
  results             StudentResult[]
  assignments         StudentAssignment[]
  certificates        StudentCertificate[]
  documents           StudentDocument[]
  notifications       StudentNotification[]
  facultyProfile       FacultyProfile?
  assignmentDefs       AssignmentDef[]
  facultyNotes         FacultyNotes[]
  quizzes              FacultyQuiz[]
  leaves               FacultyLeave[]
  facultyNotifications FacultyNotification[]
  timetableEntries             TimetableEntry[]
  substituteRequestsOriginal   SubstituteFaculty[] @relation(name: "OriginalFaculty")
  substituteRequestsSubstitute SubstituteFaculty[] @relation(name: "SubstituteFaculty")
  timetableApprovals           TimetableApproval[]
  attendanceSessions           AttendanceSession[]
  attendanceRecords            AttendanceRecord[]
  attendanceCorrections        AttendanceCorrection[]
  attendanceAudits             AttendanceAudit[]
  defaulters                   DefaulterList[]
  qrScanLogs                   QRScanLog[]
  faceProfile                  FaceProfile?
  faceVerifications            FaceVerification[]
  faceAudits                   FaceAudit[]
  faceApprovedRegistrations    FaceRegistration[]
  assignmentsCreated           Assignment[]
  assignmentSubmissions        AssignmentSubmission[]
  assignmentFeedbacks          AssignmentFeedback[]
  assignmentAudits             AssignmentAudit[]
  examsCreated                 Exam[]
  examsInvigilated             ExamSchedule[]           @relation("InvigilatorUser")
  examsSuperintended           ExamSchedule[]           @relation("ChiefSuperintendentUser")
  examsObserved                ExamSchedule[]           @relation("ObserverUser")
  examInvigilatorDuties        ExamInvigilator[]
  hallTickets                  HallTicket[]
  approvedQuestionPapers       QuestionPaper[]          @relation("QuestionPaperApprover")
  examAudits                   ExamAudit[]
  resultsCompiled              Result[]
  transcripts                  Transcript[]
  revaluationRequests          RevaluationRequest[]     @relation("StudentRevaluation")
  revaluationApproved          RevaluationRequest[]     @relation("FacultyChecker")
  meritList                    MeritList[]
  resultAudits                 ResultAudit[]
  parentProfile                ParentProfile?
  parentLinks                  ParentStudentLink[]
  sentParentMessages           ParentMessage[]          @relation("ParentSent")
  receivedParentMessages       ParentMessage[]          @relation("ParentReceived")
  parentAudits                 ParentAudit[]
  libraryMembership            LibraryMembership?
  loansIssued                  BookLoan[]               @relation("LoansIssued")
  renewalsCreated              LoanRenewal[]            @relation("RenewalsCreated")
  finesWaived                  LibraryFine[]            @relation("FinesWaived")
  inventoryEvents              LibraryInventoryEvent[]  @relation("InventoryEvents")
  acquisitionRequests          BookAcquisitionRequest[] @relation("RequestedAcquisitions")
  acquisitionApprovals         BookAcquisitionRequest[] @relation("ApprovedAcquisitions")
  inventoryAudits              InventoryAudit[]         @relation("ConductedAudits")
  libraryAudits                LibraryAudit[]
  hostelApplications           HostelApplication[]      @relation("StudentApplications")
  reviewedHostelApplications   HostelApplication[]      @relation("WardenReviewedApplications")
  hostelAllocations            HostelAllocation[]       @relation("StudentAllocations")
  allocatedHostels             HostelAllocation[]       @relation("WardenAllocations")
  wardenAssignments            HostelWardenAssignment[] @relation("WardenAssignments")
  visitorRequests              HostelVisitor[]          @relation("StudentVisitors")
  approvedVisitors             HostelVisitor[]          @relation("WardenVisitors")
  hostelComplaints             HostelComplaint[]        @relation("StudentComplaints")
  assignedComplaints           HostelComplaint[]        @relation("AssignedComplaints")
  hostelComplaintComments      HostelComplaintComment[] @relation("UserComplaintComments")
  assignedMaintenance          HostelMaintenanceRequest[] @relation("AssignedMaintenance")
  hostelLeaveRequests          HostelLeaveRequest[]     @relation("StudentLeaves")
  gatePasses                   HostelGatePass[]         @relation("StudentGatePasses")
  messSubscriptions            MessSubscription[]       @relation("StudentSubscriptions")
  messAttendances              MessAttendance[]         @relation("StudentMessAttendance")
  hostelFines                  HostelFine[]             @relation("StudentFines")
  waivedHostelFines            HostelFine[]             @relation("WardenWaivedFines")
  reportedIncidents            HostelIncident[]         @relation("ReporterIncidents")
  hostelAudits                 HostelAudit[]
  transportDriverProfile       TransportDriverProfile?
  transportStaffProfile        TransportStaffProfile?
  transportApplications        TransportApplication[]   @relation("ApplicantApplications")
  reviewedTransportApplications TransportApplication[]  @relation("TransportManagerReviewed")
  transportSubscriptions       TransportSubscription[]  @relation("UserSubscriptions")
  approvedSubscriptions        TransportSubscription[]  @relation("ManagerApprovedSubscriptions")
  allocatedSeats               TransportSeatAllocation[] @relation("AllocatedByUser")
  transportPasses              TransportPass[]          @relation("UserPasses")
  boardedTrips                 TransportBoarding[]      @relation("BoardedUser")
  verifiedBoardings            TransportBoarding[]      @relation("BoardingVerifier")
  recordedFuelLogs             TransportFuelLog[]       @relation("FuelRecorder")
  reportedTransportIncidents   TransportIncident[]      @relation("ReporterIncidents")
  transportAudits              TransportAudit[]
  meetingsAsParent             ParentTeacherMeeting[]   @relation("MeetingParent")
  meetingsAsStudent            ParentTeacherMeeting[]   @relation("MeetingStudent")
  meetingsAsTeacher            ParentTeacherMeeting[]   @relation("MeetingTeacher")
  meetingNotesWritten          ParentMeetingNote[]
  parentConsents               ParentConsent[]
  studentConsents              ParentConsent[]          @relation("ConsentStudent")
  receivedNotifications        Notification[]           @relation("NotificationRecipient")
  sentNotifications            Notification[]           @relation("NotificationSender")
  notificationPreference       NotificationPreference?
  createdAnnouncements         Announcement[]           @relation("AnnouncementAuthor")
  createdTemplates             NotificationTemplate[]   @relation("TemplateCreator")
  readReceipts                 NotificationReadReceipt[]
  createdCampaigns             BroadcastCampaign[]      @relation("CampaignCreator")
  broadcastRecipients          BroadcastRecipient[]
  createdEmergencyAlerts       EmergencyAlert[]         @relation("EmergencyAlertCreator")
  communicationAudits          CommunicationAudit[]
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([email])
  @@index([username])
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Permission {
  id              String           @id @default(uuid())
  name            String           @unique
  description     String?
  userPermissions UserPermission[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model UserPermission {
  id           String     @id @default(uuid())
  userId       String
  permissionId String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([userId, permissionId])
}

model UserSession {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceInfo   String?
  ipAddress    String?
  lastActivity DateTime @default(now()) @updatedAt
  expiresAt    DateTime
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model LoginHistory {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress  String?
  deviceInfo String?
  status     String
  createdAt  DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  details    String?  @db.Text
  ipAddress  String?
  createdAt  DateTime @default(now())
}

model UserProfile {
  id               String       @id @default(uuid())
  userId           String       @unique
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  phoneNumber      String?
  bio              String?      @db.Text
  address          String?      @db.Text
  avatarUrl        String?
  designationId    String?
  designation      Designation? @relation(fields: [designationId], references: [id], onDelete: SetNull)
  usn              String?      @unique
  parentName       String?
  parentPhone      String?
  emergencyContact String?
  bloodGroup       String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model Department {
  id           String        @id @default(uuid())
  name         String        @unique
  code         String        @unique
  description  String?
  deanHod      String?
  email        String?
  phone        String?
  building     String?
  status       String        @default("ACTIVE")
  users        User[]
  programs     Program[]
  courses      Course[]
  subjects     Subject[]
  sections     Section[]
  rooms              Room[]
  laboratories       Laboratory[]
  facultyAssignments FacultyAssignment[]
  attendanceSessions AttendanceSession[]
  assignments        Assignment[]
  exams              Exam[]
  resultAnalytics    ResultAnalytics[]
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

model Section {
  id                 String              @id @default(uuid())
  name               String
  capacity           Int
  semesterId         String
  semester           Semester            @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  departmentId       String
  department         Department          @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  programId          String
  program            Program             @relation(fields: [programId], references: [id], onDelete: Cascade)
  facultyAdvisorId   String?
  facultyAdvisor     User?               @relation(name: "FacultyAdvisor", fields: [facultyAdvisorId], references: [id], onDelete: SetNull)
  academicYearId     String?
  academicYear       AcademicYear?       @relation(fields: [academicYearId], references: [id], onDelete: SetNull)
  users              User[]
  facultyAssignments FacultyAssignment[]
  timetables         Timetable[]
  attendanceSessions AttendanceSession[]
  defaulters         DefaulterList[]
  assignments        Assignment[]
  exams              Exam[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model AcademicYear {
  id                   String              @id @default(uuid())
  name                 String              @unique
  startDate            DateTime
  endDate              DateTime
  status               String              @default("ACTIVE") // ACTIVE, INACTIVE
  currentAcademicYear  Boolean             @default(false)
  semesters            Semester[]
  sections             Section[]
  facultyAssignments   FacultyAssignment[]
  calendars            AcademicCalendar[]
  timetables           Timetable[]
  attendanceSessions   AttendanceSession[]
  assignments          Assignment[]
  exams                Exam[]
  results              Result[]
  gradeSchemes         GradeScheme[]
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
}

model Program {
  id           String     @id @default(uuid())
  name         String     @unique
  code         String     @unique
  description  String?
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  courses      Course[]
  sections     Section[]
  semesters    Semester[]
  attendanceSessions AttendanceSession[]
  assignments        Assignment[]
  exams              Exam[]
  gradeSchemes       GradeScheme[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Course {
  id           String     @id @default(uuid())
  code         String     @unique
  name         String
  credits      Int
  duration     String
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  programId    String
  program      Program    @relation(fields: [programId], references: [id], onDelete: Cascade)
  description  String?
  status       String     @default("ACTIVE")
  subjects     Subject[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Semester {
  id                 String              @id @default(uuid())
  semesterNumber     Int
  academicYearId     String
  academicYear       AcademicYear        @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  programId          String
  program            Program             @relation(fields: [programId], references: [id], onDelete: Cascade)
  startDate          DateTime
  endDate            DateTime
  currentSemester    Boolean             @default(false)
  subjects           Subject[]
  sections           Section[]
  facultyAssignments FacultyAssignment[]
  timetables         Timetable[]
  attendanceSessions AttendanceSession[]
  assignments        Assignment[]
  exams              Exam[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model Subject {
  id                 String              @id @default(uuid())
  code               String              @unique
  name               String
  credits            Int
  theoryHours        Int                 @default(0)
  labHours           Int                 @default(0)
  elective           Boolean             @default(false)
  mandatory          Boolean             @default(true)
  departmentId        String
  department          Department          @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  semesterId          String
  semester            Semester            @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  courseId            String
  course              Course              @relation(fields: [courseId], references: [id], onDelete: Cascade)
  facultyAssignments  FacultyAssignment[]
  attendanceSummaries StudentAttendanceSummary[]
  results             StudentResult[]
  assignments         StudentAssignment[]
  assignmentDefs      AssignmentDef[]
  facultyNotes        FacultyNotes[]
  quizzes             FacultyQuiz[]
  timetableEntries    TimetableEntry[]
  attendanceSessions  AttendanceSession[]
  defaulters          DefaulterList[]
  subjectAssignments  Assignment[]
  subjectExams        Exam[]
  resultDetails       ResultDetail[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
}

model Building {
  id          String   @id @default(uuid())
  name        String   @unique
  code        String   @unique
  floors      Int
  description String?
  rooms       Room[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Room {
  id               String     @id @default(uuid())
  roomNumber       String     @unique
  roomType         String     @default("CLASSROOM") // CLASSROOM, SEMINAR_HALL, AUDITORIUM
  capacity         Int
  buildingId       String
  building         Building   @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  floor            Int
  projector        Boolean    @default(false)
  smartBoard       Boolean    @default(false)
  airConditioning  Boolean    @default(false)
  status           String     @default("ACTIVE")
  departmentId     String?
  department       Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  timetableEntries TimetableEntry[]
  examSchedules    ExamSchedule[]
}

model Laboratory {
  id           String     @id @default(uuid())
  labName      String     @unique
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  capacity     Int
  systems      Int        @default(0)
  software     String?    @db.Text
  labAssistant String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  timetableEntries TimetableEntry[]
  examSchedules    ExamSchedule[]
}

model FacultyAssignment {
  id             String        @id @default(uuid())
  departmentId   String
  department     Department    @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  subjectId      String
  subject        Subject       @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  facultyId      String
  faculty        User          @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  sectionId      String
  section        Section       @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  semesterId     String
  semester       Semester      @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  academicYearId String
  academicYear   AcademicYear  @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([facultyId, subjectId, sectionId, semesterId, academicYearId])
}

model Designation {
  id           String        @id @default(uuid())
  name         String        @unique
  code         String        @unique
  description  String?
  userProfiles UserProfile[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model StudentAttendanceSummary {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjectId      String
  subject        Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  totalClasses   Int
  presentClasses Int
  percentage     Float
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, subjectId])
}

model StudentResult {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjectId      String
  subject        Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  semesterNumber Int
  internalMarks  Int
  externalMarks  Int
  grade          String
  credits        Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, subjectId])
}

model StudentAssignment {
  id               String         @id @default(uuid())
  userId           String
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjectId        String
  subject          Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  title            String
  description      String?        @db.Text
  dueDate          DateTime
  submissionStatus String         @default("PENDING") // PENDING, SUBMITTED, LATE, GRADED
  submissionUrl    String?
  submittedAt      DateTime?
  grade            String?
  assignmentDefId  String?
  assignmentDef    AssignmentDef? @relation(fields: [assignmentDefId], references: [id], onDelete: Cascade)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model StudentCertificate {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  certificateType String    // BONAFIDE, STUDY, TRANSFER, FEE_RECEIPT
  status          String    @default("PENDING") // PENDING, APPROVED, REJECTED
  documentUrl     String?
  requestedAt     DateTime  @default(now())
  issuedAt        DateTime?
}

model StudentDocument {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String   // ID Card, Admission Letter, etc.
  documentUrl String
  uploadedAt  DateTime @default(now())
}

model StudentNotification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  content   String   @db.Text
  type      String   // ANNOUNCEMENT, EVENT, PLACEMENT, ASSIGNMENT, EXAM, FEE
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model FacultyProfile {
  id               String   @id @default(uuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  employeeId       String   @unique
  officeHours      String?
  qualification    String?
  experience       String?
  researchArea     String?
  specialization   String?
  officeLocation   String?
  emergencyContact String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model AssignmentDef {
  id                String              @id @default(uuid())
  title             String
  description       String?             @db.Text
  dueDate           DateTime
  allowResubmission Boolean             @default(false)
  attachmentUrl     String?
  subjectId         String
  subject           Subject             @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  facultyId         String
  faculty           User                @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  studentSubmissions StudentAssignment[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
}

model FacultyNotes {
  id            String   @id @default(uuid())
  title         String
  fileUrl       String
  fileType      String   // PDF, PPT, DOCX, etc.
  subjectId     String
  subject       Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  facultyId     String
  faculty       User     @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model FacultyQuiz {
  id            String    @id @default(uuid())
  title         String
  subjectId     String
  subject       Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  facultyId     String
  faculty       User      @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  questionsJson String    @db.Text
  status        String    @default("DRAFT") // DRAFT, PUBLISHED
  scheduledAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model FacultyLeave {
  id          String    @id @default(uuid())
  facultyId   String
  faculty     User      @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  leaveType   String    // CASUAL, SICK, EARNED
  startDate   DateTime
  endDate     DateTime
  reason      String    @db.Text
  status      String    @default("PENDING") // PENDING, APPROVED, REJECTED
  requestedAt DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model FacultyNotification {
  id        String   @id @default(uuid())
  facultyId String
  faculty   User     @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  title     String
  content   String   @db.Text
  type      String   // ADMIN, DEPT, MEETING, EXAM, ASSIGNMENT
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model AcademicCalendar {
  id             String          @id @default(uuid())
  academicYearId String
  academicYear   AcademicYear    @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  version        Int             @default(1)
  workingDays    String          // JSON string like ["MONDAY", "TUESDAY"]
  events         CalendarEvent[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model CalendarEvent {
  id          String           @id @default(uuid())
  calendarId  String
  calendar    AcademicCalendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  title       String
  eventDate   DateTime
  type        String           // HOLIDAY, EXAM_DAY, COLLEGE_EVENT, SPECIAL_WORKING_DAY
  description String?          @db.Text
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model TimeSlot {
  id               String           @id @default(uuid())
  name             String           // Period 1, Lunch Break, etc.
  startTime        String
  endTime          String
  type             String           // CLASS, BREAK, LAB, EXTRA
  timetableEntries TimetableEntry[]
  attendanceSessions AttendanceSession[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model Timetable {
  id             String              @id @default(uuid())
  name           String
  academicYearId String
  academicYear   AcademicYear        @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  semesterId     String
  semester       Semester            @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  sectionId      String
  section        Section             @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  status         String              @default("DRAFT") // DRAFT, REVIEW_PENDING, PUBLISHED, ARCHIVED
  version        Int                 @default(1)
  entries        TimetableEntry[]
  approvals      TimetableApproval[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

model TimetableEntry {
  id                 String              @id @default(uuid())
  timetableId        String
  timetable          Timetable           @relation(fields: [timetableId], references: [id], onDelete: Cascade)
  dayOfWeek          String              // MONDAY, TUESDAY, etc.
  timeSlotId         String
  timeSlot           TimeSlot            @relation(fields: [timeSlotId], references: [id], onDelete: Cascade)
  subjectId          String?
  subject            Subject?            @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  facultyId          String?
  faculty            User?               @relation(fields: [facultyId], references: [id], onDelete: SetNull)
  roomId             String?
  room               Room?               @relation(fields: [roomId], references: [id], onDelete: SetNull)
  labId              String?
  lab                Laboratory?         @relation(fields: [labId], references: [id], onDelete: SetNull)
  substituteRequests SubstituteFaculty[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model SubstituteFaculty {
  id                 String         @id @default(uuid())
  date               DateTime
  timetableEntryId   String
  timetableEntry     TimetableEntry @relation(fields: [timetableEntryId], references: [id], onDelete: Cascade)
  originalFacultyId  String
  originalFaculty    User           @relation(name: "OriginalFaculty", fields: [originalFacultyId], references: [id], onDelete: Cascade)
  substituteFacultyId String
  substituteFaculty  User           @relation(name: "SubstituteFaculty", fields: [substituteFacultyId], references: [id], onDelete: Cascade)
  status             String         @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

model TimetableApproval {
  id          String    @id @default(uuid())
  timetableId String
  timetable   Timetable @relation(fields: [timetableId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  stage       String    // DEPT_REVIEW, ACADEMIC_OFFICE, MASTER_ADMIN
  status      String    // APPROVED, REJECTED
  remarks     String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model AttendanceSession {
  id             String             @id @default(uuid())
  academicYearId String
  academicYear   AcademicYear       @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  departmentId   String
  department     Department         @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  programId      String
  program        Program            @relation(fields: [programId], references: [id], onDelete: Cascade)
  semesterId     String
  semester       Semester           @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  sectionId      String
  section        Section            @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  subjectId      String
  subject        Subject            @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  timeSlotId     String?
  timeSlot       TimeSlot?          @relation(fields: [timeSlotId], references: [id], onDelete: SetNull)
  date           DateTime
  status         String             @default("ACTIVE") // ACTIVE, CLOSED
  facultyId      String
  faculty        User               @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  records        AttendanceRecord[]
  audits         AttendanceAudit[]
  qrSession      QRSession?
  faceAttendances FaceAttendance[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([date])
}

model AttendanceRecord {
  id          String                 @id @default(uuid())
  sessionId   String
  session     AttendanceSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  studentId   String
  student     User                   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status      String                 // PRESENT, ABSENT, LATE, MEDICAL_LEAVE, ON_DUTY
  corrections AttendanceCorrection[]
  audits      AttendanceAudit[]
  faceAttendance FaceAttendance?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@unique([sessionId, studentId])
}

model AttendanceCorrection {
  id              String           @id @default(uuid())
  recordId        String
  record          AttendanceRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  studentId       String
  student         User             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  requestedStatus String           // PRESENT, ON_DUTY, etc.
  reason          String           @db.Text
  status          String           @default("PENDING") // PENDING, APPROVED, REJECTED
  comments        String?          @db.Text
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model AttendanceAudit {
  id         String            @id @default(uuid())
  sessionId  String?
  session    AttendanceSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  recordId   String?
  record     AttendanceRecord?  @relation(fields: [recordId], references: [id], onDelete: SetNull)
  userId     String
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  action     String            // CREATE, MODIFY, FINALIZE, APPROVE_CORRECTION
  ipAddress  String?
  userAgent  String?
  reason     String?           @db.Text
  createdAt  DateTime          @default(now())
}

model DefaulterList {
  id         String   @id @default(uuid())
  subjectId  String
  subject    Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  sectionId  String
  section    Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  studentId  String
  student    User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  percentage Float
  category   String   // BELOW_75, BELOW_65, BELOW_50
  createdAt  DateTime @default(now())
}

model QRSession {
  id                  String             @id @default(uuid())
  attendanceSessionId String             @unique
  attendanceSession   AttendanceSession  @relation(fields: [attendanceSessionId], references: [id], onDelete: Cascade)
  latitude            Float
  longitude           Float
  allowedRadius       Float              @default(100.0) // allowed radius in meters
  intervalSeconds     Int                @default(30)
  status              String             @default("ACTIVE") // ACTIVE, CLOSED
  codes               QRCode[]
  scanLogs            QRScanLog[]
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
}

model QRCode {
  id          String    @id @default(uuid())
  qrSessionId String
  qrSession   QRSession @relation(fields: [qrSessionId], references: [id], onDelete: Cascade)
  codeValue   String    @unique
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
}

model QRScanLog {
  id               String            @id @default(uuid())
  qrSessionId      String
  qrSession        QRSession         @relation(fields: [qrSessionId], references: [id], onDelete: Cascade)
  studentId        String
  student          User              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  scannedToken     String
  isSuccess        Boolean
  failReason       String?
  geoValidation    GeoValidation?
  deviceValidation DeviceValidation?
  createdAt        DateTime          @default(now())
}

model GeoValidation {
  id               String    @id @default(uuid())
  scanLogId        String    @unique
  scanLog          QRScanLog @relation(fields: [scanLogId], references: [id], onDelete: Cascade)
  studentLatitude  Float
  studentLongitude Float
  distanceMeters   Float
  createdAt        DateTime  @default(now())
}

model DeviceValidation {
  id        String    @id @default(uuid())
  scanLogId String    @unique
  scanLog   QRScanLog @relation(fields: [scanLogId], references: [id], onDelete: Cascade)
  deviceId  String
  browser   String?
  os        String?
  ipAddress String?
  createdAt DateTime  @default(now())
}

model FaceProfile {
  id              String             @id @default(uuid())
  userId          String             @unique
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  status          String             @default("PENDING") // PENDING, APPROVED, REJECTED
  embeddings      FaceEmbedding[]
  verifications   FaceVerification[]
  livenessChecks  LivenessCheck[]
  spoofDetections SpoofDetection[]
  registrations   FaceRegistration[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model FaceEmbedding {
  id            String      @id @default(uuid())
  faceProfileId String
  faceProfile   FaceProfile @relation(fields: [faceProfileId], references: [id], onDelete: Cascade)
  angle         String      // FRONT, LEFT, RIGHT, UP, DOWN
  embeddingJson String      @db.Text
  createdAt     DateTime    @default(now())
}

model FaceRegistration {
  id             String      @id @default(uuid())
  faceProfileId  String
  faceProfile    FaceProfile @relation(fields: [faceProfileId], references: [id], onDelete: Cascade)
  adminId        String?
  admin          User?       @relation(fields: [adminId], references: [id], onDelete: SetNull)
  status         String      // APPROVED, REJECTED
  rejectionReason String?
  createdAt      DateTime    @default(now())
}

model FaceVerification {
  id               String          @id @default(uuid())
  userId           String?
  user             User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  faceProfileId    String?
  faceProfile      FaceProfile?    @relation(fields: [faceProfileId], references: [id], onDelete: Cascade)
  isSuccess        Boolean
  confidence       Float
  verificationType String          // LOGIN, ATTENDANCE, GENERAL
  faceAttendance   FaceAttendance?
  livenessChecks   LivenessCheck[]
  spoofDetections  SpoofDetection[]
  createdAt        DateTime        @default(now())
}

model FaceAttendance {
  id                  String            @id @default(uuid())
  attendanceSessionId String
  attendanceSession   AttendanceSession @relation(fields: [attendanceSessionId], references: [id], onDelete: Cascade)
  attendanceRecordId  String            @unique
  attendanceRecord    AttendanceRecord  @relation(fields: [attendanceRecordId], references: [id], onDelete: Cascade)
  verificationId      String            @unique
  verification        FaceVerification  @relation(fields: [verificationId], references: [id], onDelete: Cascade)
  createdAt           DateTime          @default(now())
}

model FaceAudit {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String   // RESET_REGISTRATION, DELETE_EMBEDDING, APPROVE_BIOMETRICS, REJECT_BIOMETRICS
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
}

model LivenessCheck {
  id                   String            @id @default(uuid())
  faceProfileId        String?
  faceProfile          FaceProfile?      @relation(fields: [faceProfileId], references: [id], onDelete: Cascade)
  verificationId       String?
  verification         FaceVerification? @relation(fields: [verificationId], references: [id], onDelete: Cascade)
  blinkCount           Int               @default(0)
  smileDetected        Boolean           @default(false)
  headRotationDegrees  Float             @default(0.0)
  isPassed             Boolean
  createdAt            DateTime          @default(now())
}

model SpoofDetection {
  id               String            @id @default(uuid())
  faceProfileId    String?
  faceProfile      FaceProfile?      @relation(fields: [faceProfileId], references: [id], onDelete: Cascade)
  verificationId   String?
  verification     FaceVerification? @relation(fields: [verificationId], references: [id], onDelete: Cascade)
  spoofProbability Float
  spoofCategory    String            // PRINTED_PHOTO, PHONE_SCREEN, REPLAY_VIDEO, NONE
  isSpoofed        Boolean
  createdAt        DateTime          @default(now())
}

model Assignment {
  id                String                 @id @default(uuid())
  academicYearId    String
  academicYear      AcademicYear           @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  departmentId      String
  department        Department             @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  programId         String
  program           Program                @relation(fields: [programId], references: [id], onDelete: Cascade)
  semesterId        String
  semester          Semester               @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  sectionId         String
  section           Section                @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  subjectId         String
  subject           Subject                @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  facultyId         String
  faculty           User                   @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  assignmentType    String                 // HOMEWORK, PROJECT, LAB, EXAM
  title             String
  description       String?                @db.Text
  instructions      String?                @db.Text
  dueDate           DateTime
  maxMarks          Float
  allowedFileTypes  String                 // Comma-separated: e.g. "PDF,ZIP"
  maxUploadSizeMb   Float                  @default(10.0)
  status            String                 @default("DRAFT") // DRAFT, PUBLISHED
  files             AssignmentFile[]
  submissions       AssignmentSubmission[]
  audits            AssignmentAudit[]
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
}

model AssignmentFile {
  id           String     @id @default(uuid())
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  fileName     String
  fileUrl      String
  fileSize     Int
  createdAt    DateTime   @default(now())
}

model AssignmentSubmission {
  id           String                 @id @default(uuid())
  assignmentId String
  assignment   Assignment             @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentId    String
  student      User                   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status       String                 @default("SUBMITTED") // SUBMITTED, LATE, GRADED
  submittedAt  DateTime               @default(now())
  attachments  SubmissionAttachment[]
  grade        AssignmentGrade?
  feedback     AssignmentFeedback[]
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@unique([assignmentId, studentId])
}

model SubmissionAttachment {
  id           String               @id @default(uuid())
  submissionId String
  submission   AssignmentSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  fileName     String
  fileUrl      String
  fileSize     Int
  createdAt    DateTime             @default(now())
}

model AssignmentFeedback {
  id               String               @id @default(uuid())
  submissionId     String
  submission       AssignmentSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  facultyId        String
  faculty          User                 @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  comments         String               @db.Text
  annotatedFileUrl String?
  createdAt        DateTime             @default(now())
}

model AssignmentGrade {
  id           String               @id @default(uuid())
  submissionId String               @unique
  submission   AssignmentSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  marksObtained Float
  isPublished  Boolean              @default(false)
  gradedAt     DateTime             @default(now())
}

model AssignmentAudit {
  id           String      @id @default(uuid())
  assignmentId String?
  assignment   Assignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  action       String      // CREATE_ASSIGNMENT, SUBMIT_ASSIGNMENT, GRADE_ASSIGNMENT, PUBLISH_GRADES
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime    @default(now())
}

model Exam {
  id              String         @id @default(uuid())
  examName        String
  examType        String         // INTERNAL, MID, LAB, PRACTICAL, SEMESTER, SUPPLEMENTARY, IMPROVEMENT, CUSTOM
  academicYearId  String
  academicYear    AcademicYear   @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  departmentId    String
  department      Department     @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  programId       String
  program         Program        @relation(fields: [programId], references: [id], onDelete: Cascade)
  semesterId      String
  semester        Semester       @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  sectionId       String
  section         Section        @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  subjectId       String
  subject         Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  facultyId       String?
  creator         User?          @relation(fields: [facultyId], references: [id], onDelete: SetNull)
  examDate        DateTime
  startTime       String         // HH:MM
  endTime         String         // HH:MM
  durationMinutes Int
  maxMarks        Float
  passingMarks    Float
  instructions    String?        @db.Text
  status          String         @default("ACTIVE") // ACTIVE, CANCELLED, COMPLETED
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  schedules       ExamSchedule[]
  hallTickets     HallTicket[]
  questionPapers  QuestionPaper[]
  audits          ExamAudit[]
}

model ExamSchedule {
  id                    String      @id @default(uuid())
  examId                String
  exam                  Exam        @relation(fields: [examId], references: [id], onDelete: Cascade)
  roomId                String?
  room                  Room?       @relation(fields: [roomId], references: [id], onDelete: SetNull)
  labId                 String?
  lab                   Laboratory? @relation(fields: [labId], references: [id], onDelete: SetNull)
  invigilatorId         String?
  invigilator           User?       @relation(name: "InvigilatorUser", fields: [invigilatorId], references: [id], onDelete: SetNull)
  chiefSuperintendentId String?
  chiefSuperintendent   User?       @relation(name: "ChiefSuperintendentUser", fields: [chiefSuperintendentId], references: [id], onDelete: SetNull)
  observerId            String?
  observer              User?       @relation(name: "ObserverUser", fields: [observerId], references: [id], onDelete: SetNull)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
}

model ExamRoom {
  id            String   @id @default(uuid())
  blockName     String
  roomNumber    String
  totalBenches  Int
  seatsPerBench Int
  capacity      Int
  createdAt     DateTime @default(now())
}

model ExamInvigilator {
  id               String   @id @default(uuid())
  facultyId        String
  faculty          User     @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  roomNumber       String
  blockName        String
  shift            String   // MORNING, AFTERNOON
  attendanceStatus String   @default("PRESENT") // PRESENT, ABSENT
  dutyReport       String?  @db.Text
  createdAt        DateTime @default(now())
}

model HallTicket {
  id               String           @id @default(uuid())
  hallTicketNumber String           @unique
  studentId        String
  student          User             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  examId           String
  exam             Exam             @relation(fields: [examId], references: [id], onDelete: Cascade)
  qrCodeUrl        String?
  examCenter       String
  seatNumber       String?
  createdAt        DateTime         @default(now())
  seatAllocations  SeatAllocation[]
}

model SeatAllocation {
  id           String     @id @default(uuid())
  hallTicketId String
  hallTicket   HallTicket @relation(fields: [hallTicketId], references: [id], onDelete: Cascade)
  blockName    String
  roomNumber   String
  benchNumber  Int
  seatNumber   String
  createdAt    DateTime   @default(now())

  @@unique([blockName, roomNumber, benchNumber, seatNumber])
}

model QuestionPaper {
  id           String   @id @default(uuid())
  examId       String
  exam         Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  fileUrl      String
  fileName     String
  version      Int      @default(1)
  status       String   @default("PENDING") // PENDING, APPROVED, REJECTED
  approvedById String?
  approvedBy   User?    @relation(name: "QuestionPaperApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
}

model ExamAudit {
  id        String   @id @default(uuid())
  examId    String?
  exam      Exam?    @relation(fields: [examId], references: [id], onDelete: SetNull)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String   // CREATE_EXAM, UPDATE_EXAM, SCHEDULE_EXAM, DOWNLOAD_HALL_TICKET, UPLOAD_QUESTION_PAPER, APPROVE_QUESTION_PAPER
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
}

model Result {
  id             String         @id @default(uuid())
  studentId      String
  student        User           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  academicYearId String
  academicYear   AcademicYear   @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  semesterNumber Int
  sgpa           Float          @default(0.0)
  cgpa           Float          @default(0.0)
  totalMarks     Float          @default(0.0)
  percentage     Float          @default(0.0)
  creditsEarned  Int            @default(0)
  status         String         @default("DRAFT") // DRAFT, DEPT_REVIEW, EXAM_CELL_APPROVED, PUBLISHED, ARCHIVED, ROLLBACK
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  details        ResultDetail[]

  @@unique([studentId, academicYearId, semesterNumber])
}

model ResultDetail {
  id                 String               @id @default(uuid())
  resultId           String
  result             Result               @relation(fields: [resultId], references: [id], onDelete: Cascade)
  subjectId          String
  subject            Subject              @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  internalMarks      Float                @default(0.0)
  assignmentMarks    Float                @default(0.0)
  labMarks           Float                @default(0.0)
  practicalMarks     Float                @default(0.0)
  projectMarks       Float                @default(0.0)
  semesterExamMarks  Float                @default(0.0)
  graceMarks         Float                @default(0.0)
  moderationMarks    Float                @default(0.0)
  totalMarks         Float                @default(0.0)
  grade              String               @default("F")
  gradePoint         Float                @default(0.0)
  passFail           String               @default("FAIL") // PASS, FAIL
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  revaluationRequests RevaluationRequest[]

  @@unique([resultId, subjectId])
}

model GradeScheme {
  id             String          @id @default(uuid())
  academicYearId String
  academicYear   AcademicYear    @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  programId      String
  program        Program         @relation(fields: [programId], references: [id], onDelete: Cascade)
  gradeScale     String          @default("10-POINT") // 10-POINT, 4-POINT
  creditSystem   String          @default("CHOICE_BASED")
  graceRules     String?         @db.Text
  passingMarks   Float           @default(40.0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  boundaries     GradeBoundary[]
}

model GradeBoundary {
  id            String      @id @default(uuid())
  gradeSchemeId String
  gradeScheme   GradeScheme @relation(fields: [gradeSchemeId], references: [id], onDelete: Cascade)
  letterGrade   String
  gradePoint    Float
  minPercentage Float
  maxPercentage Float
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Transcript {
  id               String   @id @default(uuid())
  studentId        String
  student          User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  transcriptType   String   // SEMESTER, CONSOLIDATED
  semesterNumber   Int?
  qrCodeValue      String   @unique
  digitalSignature String
  issueDate        DateTime @default(now())
  isVerified       Boolean  @default(true)
  createdAt        DateTime @default(now())
}

model RevaluationRequest {
  id             String       @id @default(uuid())
  resultDetailId String
  resultDetail   ResultDetail @relation(fields: [resultDetailId], references: [id], onDelete: Cascade)
  studentId      String
  student        User         @relation(name: "StudentRevaluation", fields: [studentId], references: [id], onDelete: Cascade)
  requestType    String       // REVALUATION, PHOTOCOPY
  status         String       @default("PENDING") // PENDING, APPROVED, REJECTED
  paymentStatus  String       @default("PENDING") // PENDING, PAID
  remarks        String?      @db.Text
  originalMarks  Float
  updatedMarks   Float?
  facultyId      String?
  faculty        User?        @relation(name: "FacultyChecker", fields: [facultyId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model ResultAnalytics {
  id             String     @id @default(uuid())
  departmentId   String
  department     Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  semesterNumber Int
  passPercentage Float
  topPerformers  String     @db.Text // JSON list of top performers
  backlogCount   Int
  createdAt      DateTime   @default(now())
}

model MeritList {
  id                  String   @id @default(uuid())
  studentId           String
  student             User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  semesterNumber      Int
  departmentRank      Int
  semesterRank        Int
  universityRank      Int
  cgpa                Float
  isGoldMedalEligible Boolean  @default(false)
  createdAt           DateTime @default(now())
}

model ResultAudit {
  id        String   @id @default(uuid())
  resultId  String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String   // MARKS_ENTRY, MARKS_MODERATION, RESULT_PUBLISH, TRANSCRIPT_GEN, REVALUATION_REQUEST, REVALUATION_APPROVE
  details   String?  @db.Text
  createdAt DateTime @default(now())
}

model AdmissionApplication {
  id                    String                   @id @default(uuid())
  applicationNumber     String                   @unique
  academicYearId        String
  departmentId          String
  programId             String
  applicantName         String
  email                 String
  phone                 String
  dateOfBirth           DateTime
  gender                String
  nationality           String
  category              String
  quota                 String
  entranceExam          String?
  entranceScore         Float?
  previousInstitution   String?
  previousQualification String?
  previousPercentage    Float?
  address               String?                  @db.Text
  guardianName          String?
  guardianPhone         String?
  guardianEmail         String?
  status                String                   @default("DRAFT")
  submittedAt           DateTime?
  reviewedAt            DateTime?
  approvedAt            DateTime?
  rejectedAt            DateTime?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  statusHistory         AdmissionStatusHistory[]
  documents             AdmissionDocument[]
  reviews               AdmissionReview[]
  enrollments           Enrollment[]
}

model AdmissionStatusHistory {
  id            String               @id @default(uuid())
  applicationId String
  application   AdmissionApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  status        String
  changedBy     String
  remarks       String?              @db.Text
  createdAt     DateTime             @default(now())
}

model AdmissionDocument {
  id                 String                     @id @default(uuid())
  applicationId      String
  application        AdmissionApplication       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  documentCategory   String
  fileName           String
  fileUrl            String
  verificationStatus String                     @default("PENDING")
  reviewerComments   String?                    @db.Text
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  versions           AdmissionDocumentVersion[]
}

model AdmissionDocumentVersion {
  id         String            @id @default(uuid())
  documentId String
  document   AdmissionDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  fileUrl    String
  uploadedAt DateTime          @default(now())
}

model AdmissionReview {
  id            String               @id @default(uuid())
  applicationId String
  application   AdmissionApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  reviewerId    String
  action        String
  comment       String?              @db.Text
  previousStatus String
  newStatus     String
  createdAt     DateTime             @default(now())
}

model Enrollment {
  id               String               @id @default(uuid())
  applicationId    String
  application      AdmissionApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  enrollmentNumber String               @unique
  studentId        String
  usn              String               @unique
  rollNumber       String
  academicYearId   String
  departmentId     String
  programId        String
  semesterNumber   Int                  @default(1)
  sectionId        String?
  enrollmentDate   DateTime             @default(now())
  createdAt        DateTime             @default(now())
}

model FeeStructure {
  id             String                 @id @default(uuid())
  academicYearId String
  programId      String
  category       String?
  quota          String?
  currency       String                 @default("INR")
  status         String                 @default("DRAFT")
  version        Int                    @default(1)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  components     FeeComponent[]
  assignments    StudentFeeAssignment[]
}

model FeeComponent {
  id             String       @id @default(uuid())
  feeStructureId String
  feeStructure   FeeStructure @relation(fields: [feeStructureId], references: [id], onDelete: Cascade)
  name           String
  code           String
  description    String?      @db.Text
  amount         Decimal      @db.Decimal(12, 2)
  mandatory      Boolean      @default(true)
  refundable     Boolean      @default(false)
  dueDate        DateTime
  sortOrder      Int          @default(0)
}

model StudentFeeAssignment {
  id             String       @id @default(uuid())
  studentId      String
  feeStructureId String
  feeStructure   FeeStructure @relation(fields: [feeStructureId], references: [id], onDelete: Restrict)
  netPayable     Decimal      @db.Decimal(12, 2)
  createdAt      DateTime     @default(now())
}

model FeeInvoice {
  id                String        @id @default(uuid())
  invoiceNumber     String        @unique
  studentId         String
  enrollmentId      String?
  currency          String        @default("INR")
  subtotal          Decimal       @db.Decimal(12, 2)
  scholarshipAmount Decimal       @db.Decimal(12, 2) @default(0.0)
  discountAmount    Decimal       @db.Decimal(12, 2) @default(0.0)
  adjustmentAmount  Decimal       @db.Decimal(12, 2) @default(0.0)
  taxAmount         Decimal       @db.Decimal(12, 2) @default(0.0)
  totalAmount       Decimal       @db.Decimal(12, 2)
  paidAmount        Decimal       @db.Decimal(12, 2) @default(0.0)
  balanceAmount     Decimal       @db.Decimal(12, 2)
  dueDate           DateTime
  status            String        @default("DRAFT")
  issuedAt          DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  items             InvoiceItem[]
  payments          Payment[]
}

model InvoiceItem {
  id            String     @id @default(uuid())
  invoiceId     String
  invoice       FeeInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  componentName String
  componentCode String
  amount        Decimal    @db.Decimal(12, 2)
  description   String?    @db.Text
}

model Payment {
  id                String        @id @default(uuid())
  paymentNumber     String        @unique
  invoiceId         String
  invoice           FeeInvoice    @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  studentId         String
  amount            Decimal       @db.Decimal(12, 2)
  currency          String        @default("INR")
  method            String
  status            String        @default("INITIATED")
  provider          String        @default("MOCK")
  providerOrderId   String?
  providerPaymentId String?
  idempotencyKey    String        @unique
  paidAt            DateTime?
  failureReason     String?       @db.Text
  createdAt         DateTime      @default(now())
  receipts          Receipt[]
  refunds           Refund[]
}

model WebhookEvent {
  id        String   @id @default(uuid())
  eventId   String   @unique
  provider  String
  payload   String   @db.Text
  processed Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Receipt {
  id                String   @id @default(uuid())
  receiptNumber     String   @unique
  paymentId         String
  payment           Payment  @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  studentId         String
  amount            Decimal  @db.Decimal(12, 2)
  currency          String   @default("INR")
  issuedAt          DateTime @default(now())
  verificationToken String   @unique
}

model Scholarship {
  id               String                   @id @default(uuid())
  name             String
  type             String
  description      String?                  @db.Text
  percentageAmount Float?
  fixedAmount      Decimal?                 @db.Decimal(12, 2)
  maximumBenefit   Decimal?                 @db.Decimal(12, 2)
  eligibility      String?                  @db.Text
  validFrom        DateTime
  validTo          DateTime
  status           String                   @default("ACTIVE")
  applications     ScholarshipApplication[]
}

model ScholarshipApplication {
  id            String      @id @default(uuid())
  scholarshipId String
  scholarship   Scholarship @relation(fields: [scholarshipId], references: [id], onDelete: Cascade)
  studentId     String
  status        String      @default("SUBMITTED")
  remarks       String?     @db.Text
  createdAt     DateTime    @default(now())
}

model StudentScholarship {
  id            String   @id @default(uuid())
  studentId     String
  scholarshipId String
  amountAwarded Decimal  @db.Decimal(12, 2)
  awardedAt     DateTime @default(now())
}

model Discount {
  id           String   @id @default(uuid())
  name         String
  discountType String
  percentage   Float?
  fixedAmount  Decimal? @db.Decimal(12, 2)
  status       String   @default("ACTIVE")
}

model StudentDiscount {
  id         String   @id @default(uuid())
  studentId  String
  discountId String
  amount     Decimal  @db.Decimal(12, 2)
  appliedAt  DateTime @default(now())
}

model FeeAdjustment {
  id        String   @id @default(uuid())
  studentId String
  invoiceId String
  amount    Decimal  @db.Decimal(12, 2)
  reason    String
  createdBy String
  approvedBy String?
  createdAt DateTime @default(now())
}

model Refund {
  id        String   @id @default(uuid())
  paymentId String
  payment   Payment  @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  amount    Decimal  @db.Decimal(12, 2)
  reason    String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
}

model PaymentAdjustment {
  id             String   @id @default(uuid())
  paymentId      String
  amount         Decimal  @db.Decimal(12, 2)
  adjustmentType String
  createdAt      DateTime @default(now())
}

model FeeReminder {
  id           String   @id @default(uuid())
  studentId    String
  invoiceId    String
  reminderType String
  channel      String
  sentAt       DateTime @default(now())
}

model FinancialAudit {
  id           String   @id @default(uuid())
  entityType   String
  entityId     String
  action       String
  userId       String
  previousData String?  @db.Text
  newData      String?  @db.Text
  createdAt    DateTime @default(now())
}

model ParentProfile {
  id               String              @id @default(uuid())
  userId           String              @unique
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  fatherName       String?
  motherName       String?
  guardianName     String?
  relationshipType String              @default("GUARDIAN")
  occupation       String?
  phoneNumber      String
  address          String?             @db.Text
  studentLinks     ParentStudentLink[]
  notifications    ParentNotification[]
  audits           ParentAudit[]
  notificationPreference ParentNotificationPreference?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
}

model ParentStudentLink {
  id                 String        @id @default(uuid())
  parentId           String
  parent             ParentProfile @relation(fields: [parentId], references: [id], onDelete: Cascade)
  studentId          String
  student            User          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  relationship       String
  isPrimaryContact   Boolean       @default(true)
  createdAt          DateTime      @default(now())

  // Extended properties for parent portal access
  canViewAcademics       Boolean   @default(true)
  canViewAttendance      Boolean   @default(true)
  canViewResults         Boolean   @default(true)
  canViewFees            Boolean   @default(true)
  canViewLibrary         Boolean   @default(true)
  canViewHostel          Boolean   @default(true)
  canViewTransport       Boolean   @default(true)
  canReceiveNotifications Boolean  @default(true)
  status                 String    @default("VERIFIED") // PENDING, VERIFIED, SUSPENDED, REVOKED
  verifiedAt             DateTime?
  verifiedBy             String?

  @@unique([parentId, studentId])
  @@index([parentId])
  @@index([studentId])
}

model ParentMessage {
  id         String    @id @default(uuid())
  senderId   String
  sender     User      @relation("ParentSent", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User      @relation("ParentReceived", fields: [receiverId], references: [id], onDelete: Cascade)
  content    String    @db.Text
  isRead     Boolean   @default(false)
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
}

model ParentNotification {
  id        String        @id @default(uuid())
  parentId  String
  parent    ParentProfile @relation(fields: [parentId], references: [id], onDelete: Cascade)
  title     String
  message   String        @db.Text
  category  String
  isRead    Boolean       @default(false)
  createdAt DateTime      @default(now())

  @@index([parentId])
  @@index([createdAt])
}

model ParentAudit {
  id        String         @id @default(uuid())
  parentId  String?
  parent    ParentProfile? @relation(fields: [parentId], references: [id], onDelete: SetNull)
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  details   String?        @db.Text
  ipAddress String?
  createdAt DateTime       @default(now())

  @@index([parentId])
  @@index([userId])
  @@index([createdAt])
}

model ParentTeacherMeeting {
  id              String             @id @default(uuid())
  parentUserId    String
  parentUser      User               @relation("MeetingParent", fields: [parentUserId], references: [id], onDelete: Cascade)
  studentId       String
  student         User               @relation("MeetingStudent", fields: [studentId], references: [id], onDelete: Cascade)
  teacherUserId   String
  teacherUser     User               @relation("MeetingTeacher", fields: [teacherUserId], references: [id], onDelete: Cascade)
  scheduledAt     DateTime
  durationMinutes Int                @default(30)
  meetingMode     String             @default("ONLINE") // IN_PERSON, ONLINE, PHONE
  locationOrLink  String?            @db.Text
  agenda          String             @db.Text
  status          String             @default("REQUESTED") // REQUESTED, APPROVED, REJECTED, RESCHEDULED, COMPLETED, CANCELLED, NO_SHOW
  requestedBy     String             // PARENT, TEACHER, ADMIN
  approvedBy      String?
  notes           ParentMeetingNote[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([parentUserId])
  @@index([studentId])
  @@index([teacherUserId])
}

model ParentMeetingNote {
  id               String               @id @default(uuid())
  meetingId        String
  meeting          ParentTeacherMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  authorId         String
  author           User                 @relation(fields: [authorId], references: [id], onDelete: Cascade)
  noteText         String               @db.Text
  visibleToParent  Boolean              @default(true)
  staffOnly        Boolean              @default(false)
  createdAt        DateTime             @default(now())

  @@index([meetingId])
}

model ParentConsent {
  id           String    @id @default(uuid())
  parentUserId String
  parentUser   User      @relation(fields: [parentUserId], references: [id], onDelete: Cascade)
  studentId    String
  student      User      @relation("ConsentStudent", fields: [studentId], references: [id], onDelete: Cascade)
  consentType  String    // EVENT, FIELD_TRIP, MEDIA, EMERGENCY, OPTIONAL_PROGRAM
  title        String
  description  String    @db.Text
  status       String    @default("PENDING") // PENDING, APPROVED, DECLINED, REVOKED, EXPIRED
  respondedAt  DateTime?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())

  @@index([parentUserId])
  @@index([studentId])
}

model ParentNotificationPreference {
  id                      String        @id @default(uuid())
  parentProfileId         String        @unique
  parent                  ParentProfile @relation(fields: [parentProfileId], references: [id], onDelete: Cascade)
  attendanceAlerts        Boolean       @default(true)
  assignmentAlerts        Boolean       @default(true)
  examAlerts              Boolean       @default(true)
  resultAlerts            Boolean       @default(true)
  feeAlerts               Boolean       @default(true)
  libraryAlerts           Boolean       @default(true)
  hostelAlerts            Boolean       @default(true)
  transportAlerts         Boolean       @default(true)
  emergencyAlerts         Boolean       @default(true)
  eventAlerts             Boolean       @default(true)
  channels                String        @default("IN_APP,EMAIL") // IN_APP, EMAIL, SMS, PUSH
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
}

model LibraryBranch {
  id           String              @id @default(uuid())
  name         String
  code         String              @unique
  description  String?             @db.Text
  location     String?
  contactEmail String?
  contactPhone String?
  openingTime  String?
  closingTime  String?
  active       Boolean             @default(true)
  copies       BookCopy[]
  memberships  LibraryMembership[]
  policies     LibraryPolicy[]
  audits       InventoryAudit[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

model Author {
  id          String       @id @default(uuid())
  name        String       @unique
  biography   String?      @db.Text
  bookAuthors BookAuthor[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Publisher {
  id        String   @id @default(uuid())
  name      String   @unique
  address   String?  @db.Text
  books     Book[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BookCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  code      String   @unique
  books     Book[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Book {
  id              String                 @id @default(uuid())
  isbn10          String?
  isbn13          String                 @unique
  title           String
  subtitle        String?
  description     String?                @db.Text
  edition         String?
  publicationYear Int
  language        String
  pageCount       Int
  coverImageUrl   String?
  publisherId     String
  publisher       Publisher              @relation(fields: [publisherId], references: [id])
  categoryId      String
  category        BookCategory           @relation(fields: [categoryId], references: [id])
  bookAuthors     BookAuthor[]
  tags            BookTag[]
  copies          BookCopy[]
  reservations    BookReservation[]
  acquisitionItems BookAcquisitionItem[]
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@index([publisherId])
  @@index([categoryId])
}

model BookAuthor {
  id       String @id @default(uuid())
  bookId   String
  book     Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  authorId String
  author   Author @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([bookId, authorId])
  @@index([bookId])
  @@index([authorId])
}

model BookTag {
  id     String @id @default(uuid())
  bookId String
  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  name   String

  @@unique([bookId, name])
  @@index([bookId])
}

model BookCopy {
  id              String                 @id @default(uuid())
  bookId          String
  book            Book                   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  branchId        String
  branch          LibraryBranch          @relation(fields: [branchId], references: [id])
  accessionNumber String                 @unique
  barcode         String                 @unique
  qrCode          String?
  shelfLocation   String?
  rackNumber      String?
  acquisitionDate DateTime
  acquisitionPrice Decimal                @db.Decimal(10, 2)
  source          String?
  condition       String                 @default("GOOD")
  status          String                 @default("AVAILABLE") // AVAILABLE, ISSUED, RESERVED, LOST, DAMAGED, REPAIR, WITHDRAWN
  loans           BookLoan[]
  events          LibraryInventoryEvent[]
  auditItems      InventoryAuditItem[]
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@index([bookId])
  @@index([branchId])
}

model LibraryMembership {
  id               String            @id @default(uuid())
  userId           String            @unique
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  membershipNumber String            @unique
  memberType       String            // STUDENT, FACULTY, STAFF, ALUMNI, OTHER
  branchId         String?
  branch           LibraryBranch?    @relation(fields: [branchId], references: [id])
  activatedAt      DateTime
  expiresAt        DateTime
  status           String            @default("ACTIVE") // ACTIVE, SUSPENDED, EXPIRED, BLOCKED
  loans            BookLoan[]
  reservations     BookReservation[]
  fines            LibraryFine[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([branchId])
}

model LibraryPolicy {
  id               String        @id @default(uuid())
  memberType       String        // STUDENT, FACULTY, STAFF, ALUMNI, OTHER
  branchId         String
  branch           LibraryBranch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  maxBooks         Int
  loanDays         Int
  renewalLimit     Int
  reservationLimit Int
  finePerDay       Decimal       @db.Decimal(10, 2)
  graceDays        Int
  maxFine          Decimal       @db.Decimal(10, 2)
  allowRenewal     Boolean       @default(true)
  allowReservation Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@unique([memberType, branchId])
  @@index([branchId])
}

model BookLoan {
  id           String             @id @default(uuid())
  copyId       String
  copy         BookCopy           @relation(fields: [copyId], references: [id], onDelete: Cascade)
  membershipId String
  membership   LibraryMembership  @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  issuedBy     String
  issuer       User               @relation("LoansIssued", fields: [issuedBy], references: [id])
  issuedAt     DateTime           @default(now())
  dueAt        DateTime
  returnedAt   DateTime?
  status       String             @default("ACTIVE") // ACTIVE, OVERDUE, RETURNED, LOST, DAMAGED
  renewalCount Int                @default(0)
  renewals     LoanRenewal[]
  fines        LibraryFine[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([copyId])
  @@index([membershipId])
  @@index([issuedBy])
}

model LoanRenewal {
  id            String   @id @default(uuid())
  loanId        String
  loan          BookLoan @relation(fields: [loanId], references: [id], onDelete: Cascade)
  renewedBy     String
  renewer       User     @relation("RenewalsCreated", fields: [renewedBy], references: [id])
  renewedAt     DateTime @default(now())
  originalDueAt DateTime
  newDueAt      DateTime
  createdAt     DateTime @default(now())

  @@index([loanId])
  @@index([renewedBy])
}

model BookReservation {
  id             String            @id @default(uuid())
  bookId         String
  book           Book              @relation(fields: [bookId], references: [id], onDelete: Cascade)
  membershipId   String
  membership     LibraryMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  reservedAt     DateTime          @default(now())
  status         String            @default("WAITING") // WAITING, READY_FOR_PICKUP, FULFILLED, CANCELLED, EXPIRED
  pickupDeadline DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([bookId])
  @@index([membershipId])
}

model LibraryFine {
  id           String            @id @default(uuid())
  loanId       String?
  loan         BookLoan?         @relation(fields: [loanId], references: [id], onDelete: SetNull)
  membershipId String
  membership   LibraryMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  amount       Decimal           @db.Decimal(10, 2)
  currency     String            @default("INR")
  reason       String            // OVERDUE, LOST, DAMAGED, OTHER
  status       String            @default("PENDING") // PENDING, PAID, WAIVED, CANCELLED
  assessedAt   DateTime          @default(now())
  paidAt       DateTime?
  waivedAt     DateTime?
  waivedBy     String?
  waiverUser   User?             @relation("FinesWaived", fields: [waivedBy], references: [id])
  waiverReason String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([loanId])
  @@index([membershipId])
  @@index([waivedBy])
}

model LibraryInventoryEvent {
  id          String   @id @default(uuid())
  copyId      String
  copy        BookCopy @relation(fields: [copyId], references: [id], onDelete: Cascade)
  eventType   String   // CONDITION_CHANGE, DAMAGE_REPORT, LOST_REPORT, REPAIR_SENT, REPAIR_RETURNED, WITHDRAWN
  description String
  reportedBy  String
  reporter    User     @relation("InventoryEvents", fields: [reportedBy], references: [id])
  createdAt   DateTime @default(now())

  @@index([copyId])
  @@index([reportedBy])
}

model DigitalResource {
  id          String   @id @default(uuid())
  title       String
  type        String   // EBOOK, JOURNAL, RESEARCH_PAPER, INSTITUTIONAL_REPOSITORY
  description String?  @db.Text
  accessUrl   String
  licenseType String
  accessLevel String   // PUBLIC, STUDENT, FACULTY, ADMIN
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LibraryVendor {
  id            String                     @id @default(uuid())
  name          String                     @unique
  contactPerson String?
  email         String?
  phone         String?
  address       String?                    @db.Text
  requests      BookAcquisitionRequest[]
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt
}

model BookAcquisitionRequest {
  id          String                @id @default(uuid())
  vendorId    String?
  vendor      LibraryVendor?        @relation(fields: [vendorId], references: [id])
  status      String                @default("DRAFT") // DRAFT, SUBMITTED, APPROVED, REJECTED, ORDERED, RECEIVED, CANCELLED
  requestedBy String
  requester   User                  @relation("RequestedAcquisitions", fields: [requestedBy], references: [id])
  approvedBy  String?
  approver    User?                 @relation("ApprovedAcquisitions", fields: [approvedBy], references: [id])
  totalCost   Decimal               @db.Decimal(10, 2) @default(0)
  notes       String?               @db.Text
  items       BookAcquisitionItem[]
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([vendorId])
  @@index([requestedBy])
  @@index([approvedBy])
}

model BookAcquisitionItem {
