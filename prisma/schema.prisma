  leaveType       String
  reason          String           @db.Text
  destination     String
  startAt         DateTime
  expectedReturnAt DateTime
  actualReturnAt  DateTime?
  guardianContact String
  status          String           @default("PENDING") // PENDING, APPROVED, REJECTED, OUT, RETURNED, OVERDUE, CANCELLED
}

model HostelGatePass {
  id             String   @id @default(uuid())
