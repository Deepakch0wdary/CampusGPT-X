datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DISABLED
  PENDING
}

model User {
  id                  String           @id @default(uuid())
  email               String           @unique
  username            String           @unique
  passwordHash        String
  name                String
  roleId              String
  role                Role             @relation(fields: [roleId], references: [id])
  departmentId        String?
  department          Department?      @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  sectionId           String?
  section             Section?         @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  profile             UserProfile?
  status              UserStatus       @default(ACTIVE)
  isSuspended         Boolean          @default(false)
  isDisabled          Boolean          @default(false)
  mustChangePassword  Boolean          @default(true)
  failedLoginAttempts Int              @default(0)
  lockedUntil         DateTime?
  verified            Boolean          @default(false)
  userPermissions     UserPermission[]
  sessions            UserSession[]
  refreshTokens       RefreshToken[]
  loginHistories      LoginHistory[]
  auditLogs           AuditLog[]
  facultyAssignments  FacultyAssignment[]
  advisedSections     Section[]        @relation(name: "FacultyAdvisor")
  attendanceSummaries StudentAttendanceSummary[]
  results             StudentResult[]
  assignments         StudentAssignment[]
  certificates        StudentCertificate[]
  documents           StudentDocument[]
  notifications       StudentNotification[]
  facultyProfile       FacultyProfile?
  assignmentDefs       AssignmentDef[]
  facultyNotes         FacultyNotes[]
  quizzes              FacultyQuiz[]
  leaves               FacultyLeave[]
  facultyNotifications FacultyNotification[]
  timetableEntries             TimetableEntry[]
  substituteRequestsOriginal   SubstituteFaculty[] @relation(name: "OriginalFaculty")
  substituteRequestsSubstitute SubstituteFaculty[] @relation(name: "SubstituteFaculty")
  timetableApprovals           TimetableApproval[]
  attendanceSessions           AttendanceSession[]
  attendanceRecords            AttendanceRecord[]
  attendanceCorrections        AttendanceCorrection[]
  attendanceAudits             AttendanceAudit[]
  defaulters                   DefaulterList[]
  qrScanLogs                   QRScanLog[]
  faceProfile                  FaceProfile?
  faceVerifications            FaceVerification[]
  faceAudits                   FaceAudit[]
  faceApprovedRegistrations    FaceRegistration[]
  assignmentsCreated           Assignment[]
  assignmentSubmissions        AssignmentSubmission[]
  assignmentFeedbacks          AssignmentFeedback[]
  assignmentAudits             AssignmentAudit[]
  examsCreated                 Exam[]
  examsInvigilated             ExamSchedule[]           @relation("InvigilatorUser")
  examsSuperintended           ExamSchedule[]           @relation("ChiefSuperintendentUser")
  examsObserved                ExamSchedule[]           @relation("ObserverUser")
  examInvigilatorDuties        ExamInvigilator[]
  hallTickets                  HallTicket[]
  approvedQuestionPapers       QuestionPaper[]          @relation("QuestionPaperApprover")
  examAudits                   ExamAudit[]
  resultsCompiled              Result[]
  transcripts                  Transcript[]
  revaluationRequests          RevaluationRequest[]     @relation("StudentRevaluation")
  revaluationApproved          RevaluationRequest[]     @relation("FacultyChecker")
  meritList                    MeritList[]
  resultAudits                 ResultAudit[]
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([email])
  @@index([username])
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Permission {
  id              String           @id @default(uuid())
  name            String           @unique
  description     String?
  userPermissions UserPermission[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model UserPermission {
  id           String     @id @default(uuid())
  userId       String
  permissionId String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([userId, permissionId])
}

model UserSession {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceInfo   String?
  ipAddress    String?
  lastActivity DateTime @default(now()) @updatedAt
  expiresAt    DateTime
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model LoginHistory {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress  String?
  deviceInfo String?
  status     String
  createdAt  DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  details    String?  @db.Text
  ipAddress  String?
  createdAt  DateTime @default(now())
}

model UserProfile {
  id               String       @id @default(uuid())
  userId           String       @unique
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  phoneNumber      String?
  bio              String?      @db.Text
  address          String?      @db.Text
  avatarUrl        String?
  designationId    String?
  designation      Designation? @relation(fields: [designationId], references: [id], onDelete: SetNull)
  usn              String?      @unique
  parentName       String?
  parentPhone      String?
  emergencyContact String?
  bloodGroup       String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model Department {
  id           String        @id @default(uuid())
  name         String        @unique
  code         String        @unique
  description  String?
  deanHod      String?
  email        String?
  phone        String?
  building     String?
  status       String        @default("ACTIVE")
  users        User[]
  programs     Program[]
  courses      Course[]
  subjects     Subject[]
  sections     Section[]
  rooms              Room[]
  laboratories       Laboratory[]
  facultyAssignments FacultyAssignment[]
  attendanceSessions AttendanceSession[]
  assignments        Assignment[]
  exams              Exam[]
  resultAnalytics    ResultAnalytics[]
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

model Section {
  id                 String              @id @default(uuid())
  name               String
  capacity           Int
  semesterId         String
  semester           Semester            @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  departmentId       String
  department         Department          @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  programId          String
  program            Program             @relation(fields: [programId], references: [id], onDelete: Cascade)
  facultyAdvisorId   String?
  facultyAdvisor     User?               @relation(name: "FacultyAdvisor", fields: [facultyAdvisorId], references: [id], onDelete: SetNull)
  academicYearId     String?
  academicYear       AcademicYear?       @relation(fields: [academicYearId], references: [id], onDelete: SetNull)
  users              User[]
  facultyAssignments FacultyAssignment[]
  timetables         Timetable[]
  attendanceSessions AttendanceSession[]
  defaulters         DefaulterList[]
  assignments        Assignment[]
  exams              Exam[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model AcademicYear {
  id                   String              @id @default(uuid())
  name                 String              @unique
  startDate            DateTime
  endDate              DateTime
  status               String              @default("ACTIVE") // ACTIVE, INACTIVE
  currentAcademicYear  Boolean             @default(false)
  semesters            Semester[]
  sections             Section[]
  facultyAssignments   FacultyAssignment[]
  calendars            AcademicCalendar[]
  timetables           Timetable[]
  attendanceSessions   AttendanceSession[]
  assignments          Assignment[]
  exams                Exam[]
  results              Result[]
  gradeSchemes         GradeScheme[]
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
}

model Program {
  id           String     @id @default(uuid())
  name         String     @unique
  code         String     @unique
  description  String?
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  courses      Course[]
  sections     Section[]
  semesters    Semester[]
  attendanceSessions AttendanceSession[]
  assignments        Assignment[]
  exams              Exam[]
  gradeSchemes       GradeScheme[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Course {
  id           String     @id @default(uuid())
  code         String     @unique
  name         String
  credits      Int
  duration     String
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  programId    String
  program      Program    @relation(fields: [programId], references: [id], onDelete: Cascade)
  description  String?
  status       String     @default("ACTIVE")
  subjects     Subject[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Semester {
  id                 String              @id @default(uuid())
  semesterNumber     Int
  academicYearId     String
  academicYear       AcademicYear        @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  programId          String
  program            Program             @relation(fields: [programId], references: [id], onDelete: Cascade)
  startDate          DateTime
  endDate            DateTime
  currentSemester    Boolean             @default(false)
  subjects           Subject[]
  sections           Section[]
  facultyAssignments FacultyAssignment[]
  timetables         Timetable[]
  attendanceSessions AttendanceSession[]
  assignments        Assignment[]
  exams              Exam[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model Subject {
  id                 String              @id @default(uuid())
  code               String              @unique
  name               String
  credits            Int
  theoryHours        Int                 @default(0)
  labHours           Int                 @default(0)
  elective           Boolean             @default(false)
  mandatory          Boolean             @default(true)
  departmentId        String
  department          Department          @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  semesterId          String
  semester            Semester            @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  courseId            String
  course              Course              @relation(fields: [courseId], references: [id], onDelete: Cascade)
  facultyAssignments  FacultyAssignment[]
  attendanceSummaries StudentAttendanceSummary[]
  results             StudentResult[]
  assignments         StudentAssignment[]
  assignmentDefs      AssignmentDef[]
  facultyNotes        FacultyNotes[]
  quizzes             FacultyQuiz[]
  timetableEntries    TimetableEntry[]
  attendanceSessions  AttendanceSession[]
  defaulters          DefaulterList[]
  subjectAssignments  Assignment[]
  subjectExams        Exam[]
  resultDetails       ResultDetail[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
}

model Building {
  id          String   @id @default(uuid())
  name        String   @unique
  code        String   @unique
  floors      Int
  description String?
  rooms       Room[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Room {
  id               String     @id @default(uuid())
  roomNumber       String     @unique
  roomType         String     @default("CLASSROOM") // CLASSROOM, SEMINAR_HALL, AUDITORIUM
  capacity         Int
  buildingId       String
  building         Building   @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  floor            Int
  projector        Boolean    @default(false)
  smartBoard       Boolean    @default(false)
  airConditioning  Boolean    @default(false)
  status           String     @default("ACTIVE")
  departmentId     String?
  department       Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  timetableEntries TimetableEntry[]
  examSchedules    ExamSchedule[]
}

model Laboratory {
  id           String     @id @default(uuid())
  labName      String     @unique
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  capacity     Int
  systems      Int        @default(0)
  software     String?    @db.Text
  labAssistant String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  timetableEntries TimetableEntry[]
  examSchedules    ExamSchedule[]
}

model FacultyAssignment {
  id             String        @id @default(uuid())
  departmentId   String
  department     Department    @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  subjectId      String
  subject        Subject       @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  facultyId      String
  faculty        User          @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  sectionId      String
  section        Section       @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  semesterId     String
  semester       Semester      @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  academicYearId String
  academicYear   AcademicYear  @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([facultyId, subjectId, sectionId, semesterId, academicYearId])
}

model Designation {
  id           String        @id @default(uuid())
  name         String        @unique
  code         String        @unique
  description  String?
  userProfiles UserProfile[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model StudentAttendanceSummary {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjectId      String
  subject        Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  totalClasses   Int
  presentClasses Int
  percentage     Float
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, subjectId])
}

model StudentResult {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjectId      String
  subject        Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  semesterNumber Int
  internalMarks  Int
  externalMarks  Int
  grade          String
  credits        Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, subjectId])
}

model StudentAssignment {
  id               String         @id @default(uuid())
  userId           String
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjectId        String
  subject          Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  title            String
  description      String?        @db.Text
  dueDate          DateTime
  submissionStatus String         @default("PENDING") // PENDING, SUBMITTED, LATE, GRADED
  submissionUrl    String?
  submittedAt      DateTime?
  grade            String?
  assignmentDefId  String?
  assignmentDef    AssignmentDef? @relation(fields: [assignmentDefId], references: [id], onDelete: Cascade)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model StudentCertificate {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  certificateType String    // BONAFIDE, STUDY, TRANSFER, FEE_RECEIPT
  status          String    @default("PENDING") // PENDING, APPROVED, REJECTED
  documentUrl     String?
  requestedAt     DateTime  @default(now())
  issuedAt        DateTime?
}

model StudentDocument {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String   // ID Card, Admission Letter, etc.
  documentUrl String
  uploadedAt  DateTime @default(now())
}

model StudentNotification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  content   String   @db.Text
  type      String   // ANNOUNCEMENT, EVENT, PLACEMENT, ASSIGNMENT, EXAM, FEE
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model FacultyProfile {
  id               String   @id @default(uuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  employeeId       String   @unique
  officeHours      String?
  qualification    String?
  experience       String?
  researchArea     String?
  specialization   String?
  officeLocation   String?
  emergencyContact String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model AssignmentDef {
  id                String              @id @default(uuid())
  title             String
  description       String?             @db.Text
  dueDate           DateTime
  allowResubmission Boolean             @default(false)
  attachmentUrl     String?
  subjectId         String
  subject           Subject             @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  facultyId         String
  faculty           User                @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  studentSubmissions StudentAssignment[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
}

model FacultyNotes {
  id            String   @id @default(uuid())
  title         String
  fileUrl       String
  fileType      String   // PDF, PPT, DOCX, etc.
  subjectId     String
  subject       Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  facultyId     String
  faculty       User     @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model FacultyQuiz {
  id            String    @id @default(uuid())
  title         String
  subjectId     String
  subject       Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  facultyId     String
  faculty       User      @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  questionsJson String    @db.Text
  status        String    @default("DRAFT") // DRAFT, PUBLISHED
  scheduledAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model FacultyLeave {
  id          String    @id @default(uuid())
  facultyId   String
  faculty     User      @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  leaveType   String    // CASUAL, SICK, EARNED
  startDate   DateTime
  endDate     DateTime
  reason      String    @db.Text
  status      String    @default("PENDING") // PENDING, APPROVED, REJECTED
  requestedAt DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model FacultyNotification {
  id        String   @id @default(uuid())
  facultyId String
  faculty   User     @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  title     String
  content   String   @db.Text
  type      String   // ADMIN, DEPT, MEETING, EXAM, ASSIGNMENT
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model AcademicCalendar {
  id             String          @id @default(uuid())
  academicYearId String
  academicYear   AcademicYear    @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  version        Int             @default(1)
  workingDays    String          // JSON string like ["MONDAY", "TUESDAY"]
  events         CalendarEvent[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model CalendarEvent {
  id          String           @id @default(uuid())
  calendarId  String
  calendar    AcademicCalendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  title       String
  eventDate   DateTime
  type        String           // HOLIDAY, EXAM_DAY, COLLEGE_EVENT, SPECIAL_WORKING_DAY
  description String?          @db.Text
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model TimeSlot {
  id               String           @id @default(uuid())
  name             String           // Period 1, Lunch Break, etc.
  startTime        String
  endTime          String
  type             String           // CLASS, BREAK, LAB, EXTRA
  timetableEntries TimetableEntry[]
  attendanceSessions AttendanceSession[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model Timetable {
  id             String              @id @default(uuid())
  name           String
  academicYearId String
  academicYear   AcademicYear        @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  semesterId     String
  semester       Semester            @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  sectionId      String
  section        Section             @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  status         String              @default("DRAFT") // DRAFT, REVIEW_PENDING, PUBLISHED, ARCHIVED
  version        Int                 @default(1)
  entries        TimetableEntry[]
  approvals      TimetableApproval[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

model TimetableEntry {
  id                 String              @id @default(uuid())
  timetableId        String
  timetable          Timetable           @relation(fields: [timetableId], references: [id], onDelete: Cascade)
  dayOfWeek          String              // MONDAY, TUESDAY, etc.
  timeSlotId         String
  timeSlot           TimeSlot            @relation(fields: [timeSlotId], references: [id], onDelete: Cascade)
  subjectId          String?
  subject            Subject?            @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  facultyId          String?
  faculty            User?               @relation(fields: [facultyId], references: [id], onDelete: SetNull)
  roomId             String?
  room               Room?               @relation(fields: [roomId], references: [id], onDelete: SetNull)
  labId              String?
  lab                Laboratory?         @relation(fields: [labId], references: [id], onDelete: SetNull)
  substituteRequests SubstituteFaculty[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model SubstituteFaculty {
  id                 String         @id @default(uuid())
  date               DateTime
  timetableEntryId   String
  timetableEntry     TimetableEntry @relation(fields: [timetableEntryId], references: [id], onDelete: Cascade)
  originalFacultyId  String
  originalFaculty    User           @relation(name: "OriginalFaculty", fields: [originalFacultyId], references: [id], onDelete: Cascade)
  substituteFacultyId String
  substituteFaculty  User           @relation(name: "SubstituteFaculty", fields: [substituteFacultyId], references: [id], onDelete: Cascade)
  status             String         @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

model TimetableApproval {
  id          String    @id @default(uuid())
  timetableId String
  timetable   Timetable @relation(fields: [timetableId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  stage       String    // DEPT_REVIEW, ACADEMIC_OFFICE, MASTER_ADMIN
  status      String    // APPROVED, REJECTED
  remarks     String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model AttendanceSession {
  id             String             @id @default(uuid())
  academicYearId String
  academicYear   AcademicYear       @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  departmentId   String
  department     Department         @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  programId      String
  program        Program            @relation(fields: [programId], references: [id], onDelete: Cascade)
  semesterId     String
  semester       Semester           @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  sectionId      String
  section        Section            @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  subjectId      String
  subject        Subject            @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  timeSlotId     String?
  timeSlot       TimeSlot?          @relation(fields: [timeSlotId], references: [id], onDelete: SetNull)
  date           DateTime
  status         String             @default("ACTIVE") // ACTIVE, CLOSED
  facultyId      String
  faculty        User               @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  records        AttendanceRecord[]
  audits         AttendanceAudit[]
  qrSession      QRSession?
  faceAttendances FaceAttendance[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([date])
}

model AttendanceRecord {
  id          String                 @id @default(uuid())
  sessionId   String
  session     AttendanceSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  studentId   String
  student     User                   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status      String                 // PRESENT, ABSENT, LATE, MEDICAL_LEAVE, ON_DUTY
  corrections AttendanceCorrection[]
  audits      AttendanceAudit[]
  faceAttendance FaceAttendance?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@unique([sessionId, studentId])
}

model AttendanceCorrection {
  id              String           @id @default(uuid())
  recordId        String
  record          AttendanceRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  studentId       String
  student         User             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  requestedStatus String           // PRESENT, ON_DUTY, etc.
  reason          String           @db.Text
  status          String           @default("PENDING") // PENDING, APPROVED, REJECTED
  comments        String?          @db.Text
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model AttendanceAudit {
  id         String            @id @default(uuid())
  sessionId  String?
  session    AttendanceSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  recordId   String?
  record     AttendanceRecord?  @relation(fields: [recordId], references: [id], onDelete: SetNull)
  userId     String
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  action     String            // CREATE, MODIFY, FINALIZE, APPROVE_CORRECTION
  ipAddress  String?
  userAgent  String?
  reason     String?           @db.Text
  createdAt  DateTime          @default(now())
}

model DefaulterList {
  id         String   @id @default(uuid())
  subjectId  String
  subject    Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  sectionId  String
  section    Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  studentId  String
  student    User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  percentage Float
  category   String   // BELOW_75, BELOW_65, BELOW_50
  createdAt  DateTime @default(now())
}

model QRSession {
  id                  String             @id @default(uuid())
  attendanceSessionId String             @unique
  attendanceSession   AttendanceSession  @relation(fields: [attendanceSessionId], references: [id], onDelete: Cascade)
  latitude            Float
  longitude           Float
  allowedRadius       Float              @default(100.0) // allowed radius in meters
  intervalSeconds     Int                @default(30)
  status              String             @default("ACTIVE") // ACTIVE, CLOSED
  codes               QRCode[]
  scanLogs            QRScanLog[]
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
}

model QRCode {
  id          String    @id @default(uuid())
  qrSessionId String
  qrSession   QRSession @relation(fields: [qrSessionId], references: [id], onDelete: Cascade)
  codeValue   String    @unique
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
}

model QRScanLog {
  id               String            @id @default(uuid())
  qrSessionId      String
  qrSession        QRSession         @relation(fields: [qrSessionId], references: [id], onDelete: Cascade)
  studentId        String
  student          User              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  scannedToken     String
  isSuccess        Boolean
  failReason       String?
  geoValidation    GeoValidation?
  deviceValidation DeviceValidation?
  createdAt        DateTime          @default(now())
}

model GeoValidation {
  id               String    @id @default(uuid())
  scanLogId        String    @unique
  scanLog          QRScanLog @relation(fields: [scanLogId], references: [id], onDelete: Cascade)
  studentLatitude  Float
  studentLongitude Float
  distanceMeters   Float
  createdAt        DateTime  @default(now())
}

model DeviceValidation {
  id        String    @id @default(uuid())
  scanLogId String    @unique
  scanLog   QRScanLog @relation(fields: [scanLogId], references: [id], onDelete: Cascade)
  deviceId  String
  browser   String?
  os        String?
  ipAddress String?
  createdAt DateTime  @default(now())
}

model FaceProfile {
  id              String             @id @default(uuid())
  userId          String             @unique
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  status          String             @default("PENDING") // PENDING, APPROVED, REJECTED
  embeddings      FaceEmbedding[]
  verifications   FaceVerification[]
  livenessChecks  LivenessCheck[]
  spoofDetections SpoofDetection[]
  registrations   FaceRegistration[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model FaceEmbedding {
  id            String      @id @default(uuid())
  faceProfileId String
  faceProfile   FaceProfile @relation(fields: [faceProfileId], references: [id], onDelete: Cascade)
  angle         String      // FRONT, LEFT, RIGHT, UP, DOWN
  embeddingJson String      @db.Text
  createdAt     DateTime    @default(now())
}

model FaceRegistration {
  id             String      @id @default(uuid())
  faceProfileId  String
  faceProfile    FaceProfile @relation(fields: [faceProfileId], references: [id], onDelete: Cascade)
  adminId        String?
  admin          User?       @relation(fields: [adminId], references: [id], onDelete: SetNull)
  status         String      // APPROVED, REJECTED
  rejectionReason String?
  createdAt      DateTime    @default(now())
}

model FaceVerification {
  id               String          @id @default(uuid())
  userId           String?
  user             User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  faceProfileId    String?
  faceProfile      FaceProfile?    @relation(fields: [faceProfileId], references: [id], onDelete: Cascade)
  isSuccess        Boolean
  confidence       Float
  verificationType String          // LOGIN, ATTENDANCE, GENERAL
  faceAttendance   FaceAttendance?
  livenessChecks   LivenessCheck[]
  spoofDetections  SpoofDetection[]
  createdAt        DateTime        @default(now())
}

model FaceAttendance {
  id                  String            @id @default(uuid())
  attendanceSessionId String
  attendanceSession   AttendanceSession @relation(fields: [attendanceSessionId], references: [id], onDelete: Cascade)
  attendanceRecordId  String            @unique
  attendanceRecord    AttendanceRecord  @relation(fields: [attendanceRecordId], references: [id], onDelete: Cascade)
  verificationId      String            @unique
  verification        FaceVerification  @relation(fields: [verificationId], references: [id], onDelete: Cascade)
  createdAt           DateTime          @default(now())
}

model FaceAudit {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String   // RESET_REGISTRATION, DELETE_EMBEDDING, APPROVE_BIOMETRICS, REJECT_BIOMETRICS
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
}

model LivenessCheck {
  id                   String            @id @default(uuid())
  faceProfileId        String?
  faceProfile          FaceProfile?      @relation(fields: [faceProfileId], references: [id], onDelete: Cascade)
  verificationId       String?
  verification         FaceVerification? @relation(fields: [verificationId], references: [id], onDelete: Cascade)
  blinkCount           Int               @default(0)
  smileDetected        Boolean           @default(false)
  headRotationDegrees  Float             @default(0.0)
  isPassed             Boolean
  createdAt            DateTime          @default(now())
}

model SpoofDetection {
  id               String            @id @default(uuid())
  faceProfileId    String?
  faceProfile      FaceProfile?      @relation(fields: [faceProfileId], references: [id], onDelete: Cascade)
  verificationId   String?
  verification     FaceVerification? @relation(fields: [verificationId], references: [id], onDelete: Cascade)
  spoofProbability Float
  spoofCategory    String            // PRINTED_PHOTO, PHONE_SCREEN, REPLAY_VIDEO, NONE
  isSpoofed        Boolean
  createdAt        DateTime          @default(now())
}

model Assignment {
  id                String                 @id @default(uuid())
  academicYearId    String
  academicYear      AcademicYear           @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  departmentId      String
  department        Department             @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  programId         String
  program           Program                @relation(fields: [programId], references: [id], onDelete: Cascade)
  semesterId        String
  semester          Semester               @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  sectionId         String
  section           Section                @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  subjectId         String
  subject           Subject                @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  facultyId         String
  faculty           User                   @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  assignmentType    String                 // HOMEWORK, PROJECT, LAB, EXAM
  title             String
  description       String?                @db.Text
  instructions      String?                @db.Text
  dueDate           DateTime
  maxMarks          Float
  allowedFileTypes  String                 // Comma-separated: e.g. "PDF,ZIP"
  maxUploadSizeMb   Float                  @default(10.0)
  status            String                 @default("DRAFT") // DRAFT, PUBLISHED
  files             AssignmentFile[]
  submissions       AssignmentSubmission[]
  audits            AssignmentAudit[]
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
}

model AssignmentFile {
  id           String     @id @default(uuid())
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  fileName     String
  fileUrl      String
  fileSize     Int
  createdAt    DateTime   @default(now())
}

model AssignmentSubmission {
  id           String                 @id @default(uuid())
  assignmentId String
  assignment   Assignment             @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentId    String
  student      User                   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status       String                 @default("SUBMITTED") // SUBMITTED, LATE, GRADED
  submittedAt  DateTime               @default(now())
  attachments  SubmissionAttachment[]
  grade        AssignmentGrade?
  feedback     AssignmentFeedback[]
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@unique([assignmentId, studentId])
}

model SubmissionAttachment {
  id           String               @id @default(uuid())
  submissionId String
  submission   AssignmentSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  fileName     String
  fileUrl      String
  fileSize     Int
  createdAt    DateTime             @default(now())
}

model AssignmentFeedback {
  id               String               @id @default(uuid())
  submissionId     String
  submission       AssignmentSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  facultyId        String
  faculty          User                 @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  comments         String               @db.Text
  annotatedFileUrl String?
  createdAt        DateTime             @default(now())
}

model AssignmentGrade {
  id           String               @id @default(uuid())
  submissionId String               @unique
  submission   AssignmentSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  marksObtained Float
  isPublished  Boolean              @default(false)
  gradedAt     DateTime             @default(now())
}

model AssignmentAudit {
  id           String      @id @default(uuid())
  assignmentId String?
  assignment   Assignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  action       String      // CREATE_ASSIGNMENT, SUBMIT_ASSIGNMENT, GRADE_ASSIGNMENT, PUBLISH_GRADES
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime    @default(now())
}

model Exam {
  id              String         @id @default(uuid())
  examName        String
  examType        String         // INTERNAL, MID, LAB, PRACTICAL, SEMESTER, SUPPLEMENTARY, IMPROVEMENT, CUSTOM
  academicYearId  String
  academicYear    AcademicYear   @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  departmentId    String
  department      Department     @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  programId       String
  program         Program        @relation(fields: [programId], references: [id], onDelete: Cascade)
  semesterId      String
  semester        Semester       @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  sectionId       String
  section         Section        @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  subjectId       String
  subject         Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  facultyId       String?
  creator         User?          @relation(fields: [facultyId], references: [id], onDelete: SetNull)
  examDate        DateTime
  startTime       String         // HH:MM
  endTime         String         // HH:MM
  durationMinutes Int
  maxMarks        Float
  passingMarks    Float
  instructions    String?        @db.Text
  status          String         @default("ACTIVE") // ACTIVE, CANCELLED, COMPLETED
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  schedules       ExamSchedule[]
  hallTickets     HallTicket[]
  questionPapers  QuestionPaper[]
  audits          ExamAudit[]
}

model ExamSchedule {
  id                    String      @id @default(uuid())
  examId                String
  exam                  Exam        @relation(fields: [examId], references: [id], onDelete: Cascade)
  roomId                String?
  room                  Room?       @relation(fields: [roomId], references: [id], onDelete: SetNull)
  labId                 String?
  lab                   Laboratory? @relation(fields: [labId], references: [id], onDelete: SetNull)
  invigilatorId         String?
  invigilator           User?       @relation(name: "InvigilatorUser", fields: [invigilatorId], references: [id], onDelete: SetNull)
  chiefSuperintendentId String?
  chiefSuperintendent   User?       @relation(name: "ChiefSuperintendentUser", fields: [chiefSuperintendentId], references: [id], onDelete: SetNull)
  observerId            String?
  observer              User?       @relation(name: "ObserverUser", fields: [observerId], references: [id], onDelete: SetNull)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
}

model ExamRoom {
  id            String   @id @default(uuid())
  blockName     String
  roomNumber    String
  totalBenches  Int
  seatsPerBench Int
  capacity      Int
  createdAt     DateTime @default(now())
}

model ExamInvigilator {
  id               String   @id @default(uuid())
  facultyId        String
  faculty          User     @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  roomNumber       String
  blockName        String
  shift            String   // MORNING, AFTERNOON
  attendanceStatus String   @default("PRESENT") // PRESENT, ABSENT
  dutyReport       String?  @db.Text
  createdAt        DateTime @default(now())
}

model HallTicket {
  id               String           @id @default(uuid())
