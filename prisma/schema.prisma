  phone                   String
  relation                String
  studentId               String
  student                 User      @relation("StudentVisitors", fields: [studentId], references: [id], onDelete: Cascade)
  hostelId                String
  hostel                  Hostel    @relation(fields: [hostelId], references: [id])
  purpose                 String
  identityType            String
  identityReferenceMasked String
  checkInAt               DateTime  @default(now())
  checkOutAt              DateTime?
  approvedBy              String?
  approver                User?     @relation("WardenVisitors", fields: [approvedBy], references: [id])
  status                  String    @default("PENDING") // PENDING, APPROVED, CHECKED_IN, CHECKED_OUT, REJECTED
}

model HostelComplaint {
  id          String                   @id @default(uuid())
  studentId   String
  student     User                     @relation("StudentComplaints", fields: [studentId], references: [id], onDelete: Cascade)
  category    String                   // ELECTRICAL, PLUMBING, CLEANING, INTERNET, FURNITURE, SECURITY, MESS, OTHER
  priority    String                   // LOW, MEDIUM, HIGH, CRITICAL
  description String                   @db.Text
  assignedTo  String?
  assignee    User?                    @relation("AssignedComplaints", fields: [assignedTo], references: [id])
  status      String                   @default("OPEN") // OPEN, ASSIGNED, IN_PROGRESS, RESOLVED, CLOSED, REJECTED
  openedAt    DateTime                 @default(now())
  resolvedAt  DateTime?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  comments    HostelComplaintComment[]
}

model HostelComplaintComment {
  id          String          @id @default(uuid())
  complaintId String
  complaint   HostelComplaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  userId      String
  user        User            @relation("UserComplaintComments", fields: [userId], references: [id], onDelete: Cascade)
  commentText String          @db.Text
  createdAt   DateTime        @default(now())
}

model HostelMaintenanceRequest {
  id           String    @id @default(uuid())
  hostelId     String
  roomId       String?
  bedId        String?
  category     String
  description  String    @db.Text
  priority     String
  assignedTo   String
  assignee     User      @relation("AssignedMaintenance", fields: [assignedTo], references: [id])
  status       String    @default("OPEN")
  estimatedCost Decimal
  actualCost   Decimal   @default(0.0)
  openedAt     DateTime  @default(now())
  completedAt  DateTime?
}

model HostelLeaveRequest {
  id              String           @id @default(uuid())
  studentId       String
  student         User             @relation("StudentLeaves", fields: [studentId], references: [id], onDelete: Cascade)
