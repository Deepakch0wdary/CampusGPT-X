  updatedAt      DateTime               @updatedAt
  components     FeeComponent[]
  assignments    StudentFeeAssignment[]
}

model FeeComponent {
  id             String       @id @default(uuid())
  feeStructureId String
  feeStructure   FeeStructure @relation(fields: [feeStructureId], references: [id], onDelete: Cascade)
  name           String
  code           String
  description    String?      @db.Text
  amount         Decimal      @db.Decimal(12, 2)
  mandatory      Boolean      @default(true)
  refundable     Boolean      @default(false)
  dueDate        DateTime
  sortOrder      Int          @default(0)
}

model StudentFeeAssignment {
  id             String       @id @default(uuid())
  studentId      String
  feeStructureId String
  feeStructure   FeeStructure @relation(fields: [feeStructureId], references: [id], onDelete: Restrict)
  netPayable     Decimal      @db.Decimal(12, 2)
  createdAt      DateTime     @default(now())
}

model FeeInvoice {
  id                String        @id @default(uuid())
  invoiceNumber     String        @unique
  studentId         String
  enrollmentId      String?
  currency          String        @default("INR")
  subtotal          Decimal       @db.Decimal(12, 2)
  scholarshipAmount Decimal       @db.Decimal(12, 2) @default(0.0)
  discountAmount    Decimal       @db.Decimal(12, 2) @default(0.0)
  adjustmentAmount  Decimal       @db.Decimal(12, 2) @default(0.0)
  taxAmount         Decimal       @db.Decimal(12, 2) @default(0.0)
  totalAmount       Decimal       @db.Decimal(12, 2)
  paidAmount        Decimal       @db.Decimal(12, 2) @default(0.0)
  balanceAmount     Decimal       @db.Decimal(12, 2)
  dueDate           DateTime
  status            String        @default("DRAFT")
  issuedAt          DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  items             InvoiceItem[]
  payments          Payment[]
}

model InvoiceItem {
  id            String     @id @default(uuid())
  invoiceId     String
  invoice       FeeInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  componentName String
  componentCode String
  amount        Decimal    @db.Decimal(12, 2)
  description   String?    @db.Text
}

model Payment {
  id                String        @id @default(uuid())
  paymentNumber     String        @unique
  invoiceId         String
  invoice           FeeInvoice    @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  studentId         String
  amount            Decimal       @db.Decimal(12, 2)
  currency          String        @default("INR")
  method            String
  status            String        @default("INITIATED")
  provider          String        @default("MOCK")
  providerOrderId   String?
  providerPaymentId String?
  idempotencyKey    String        @unique
  paidAt            DateTime?
  failureReason     String?       @db.Text
  createdAt         DateTime      @default(now())
  receipts          Receipt[]
  refunds           Refund[]
}

model WebhookEvent {
  id        String   @id @default(uuid())
  eventId   String   @unique
  provider  String
  payload   String   @db.Text
  processed Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Receipt {
  id                String   @id @default(uuid())
  receiptNumber     String   @unique
  paymentId         String
  payment           Payment  @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  studentId         String
  amount            Decimal  @db.Decimal(12, 2)
  currency          String   @default("INR")
  issuedAt          DateTime @default(now())
  verificationToken String   @unique
}

model Scholarship {
  id               String                   @id @default(uuid())
  name             String
  type             String
  description      String?                  @db.Text
  percentageAmount Float?
  fixedAmount      Decimal?                 @db.Decimal(12, 2)
  maximumBenefit   Decimal?                 @db.Decimal(12, 2)
  eligibility      String?                  @db.Text
  validFrom        DateTime
  validTo          DateTime
  status           String                   @default("ACTIVE")
  applications     ScholarshipApplication[]
}

model ScholarshipApplication {
  id            String      @id @default(uuid())
  scholarshipId String
  scholarship   Scholarship @relation(fields: [scholarshipId], references: [id], onDelete: Cascade)
  studentId     String
  status        String      @default("SUBMITTED")
  remarks       String?     @db.Text
  createdAt     DateTime    @default(now())
}

model StudentScholarship {
  id            String   @id @default(uuid())
  studentId     String
  scholarshipId String
  amountAwarded Decimal  @db.Decimal(12, 2)
  awardedAt     DateTime @default(now())
}

model Discount {
  id           String   @id @default(uuid())
  name         String
  discountType String
  percentage   Float?
  fixedAmount  Decimal? @db.Decimal(12, 2)
  status       String   @default("ACTIVE")
}

model StudentDiscount {
  id         String   @id @default(uuid())
  studentId  String
  discountId String
  amount     Decimal  @db.Decimal(12, 2)
  appliedAt  DateTime @default(now())
}

model FeeAdjustment {
  id        String   @id @default(uuid())
  studentId String
  invoiceId String
  amount    Decimal  @db.Decimal(12, 2)
  reason    String
  createdBy String
  approvedBy String?
  createdAt DateTime @default(now())
}

model Refund {
  id        String   @id @default(uuid())
  paymentId String
  payment   Payment  @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  amount    Decimal  @db.Decimal(12, 2)
  reason    String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
}

model PaymentAdjustment {
  id             String   @id @default(uuid())
  paymentId      String
  amount         Decimal  @db.Decimal(12, 2)
  adjustmentType String
  createdAt      DateTime @default(now())
}

model FeeReminder {
  id           String   @id @default(uuid())
  studentId    String
  invoiceId    String
  reminderType String
  channel      String
  sentAt       DateTime @default(now())
}

model FinancialAudit {
  id           String   @id @default(uuid())
  entityType   String
  entityId     String
  action       String
  userId       String
  previousData String?  @db.Text
  newData      String?  @db.Text
  createdAt    DateTime @default(now())
}
