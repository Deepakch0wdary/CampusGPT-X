}

model HostelBlock {
  id          String         @id @default(uuid())
  hostelId    String
  hostel      Hostel         @relation(fields: [hostelId], references: [id], onDelete: Cascade)
  name        String
  code        String         @unique
  description String?        @db.Text
  totalFloors Int
  active      Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  floors      HostelFloor[]
}

model HostelFloor {
  id          String      @id @default(uuid())
  blockId     String
  block       HostelBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)
  floorNumber Int
  name        String
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  rooms       HostelRoom[]
}

model HostelRoom {
  id           String              @id @default(uuid())
  floorId      String
  floor        HostelFloor         @relation(fields: [floorId], references: [id], onDelete: Cascade)
  roomNumber   String              @unique
  roomType     String              // SINGLE, DOUBLE, TRIPLE, FOUR_SHARING, DORMITORY, GUEST
  capacity     Int
  monthlyRate  Decimal
  status       String              @default("AVAILABLE") // AVAILABLE, PARTIALLY_OCCUPIED, FULL, MAINTENANCE, BLOCKED
  amenities    String?             @db.Text
  active       Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  beds         HostelBed[]
}

model HostelBed {
  id          String             @id @default(uuid())
  roomId      String
  room        HostelRoom         @relation(fields: [roomId], references: [id], onDelete: Cascade)
  bedNumber   String
  status      String             @default("AVAILABLE") // AVAILABLE, ALLOCATED, RESERVED, MAINTENANCE, BLOCKED
  active      Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  allocations HostelAllocation[]
}

model HostelApplication {
  id                String             @id @default(uuid())
  studentId         String
  student           User               @relation("StudentApplications", fields: [studentId], references: [id], onDelete: Cascade)
  academicYearId    String
  preferredHostelId String
  preferredHostel   Hostel             @relation(fields: [preferredHostelId], references: [id])
  preferredRoomType String             // SINGLE, DOUBLE, TRIPLE, FOUR_SHARING, DORMITORY, GUEST
  reason            String?            @db.Text
  medicalNotes      String?            @db.Text
  emergencyContact  String
  status            String             @default("SUBMITTED") // DRAFT, SUBMITTED, UNDER_REVIEW, APPROVED, REJECTED, WAITLISTED, ALLOCATED, CANCELLED
  submittedAt       DateTime           @default(now())
  reviewedAt        DateTime?
  reviewedBy        String?
  reviewer          User?              @relation("WardenReviewedApplications", fields: [reviewedBy], references: [id])
  allocations       HostelAllocation[]
}

model HostelAllocation {
  id             String                 @id @default(uuid())
  studentId      String
  student        User                   @relation("StudentAllocations", fields: [studentId], references: [id], onDelete: Cascade)
  applicationId  String
