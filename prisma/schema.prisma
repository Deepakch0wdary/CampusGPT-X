}

model ResultDetail {
  id                 String               @id @default(uuid())
  resultId           String
  result             Result               @relation(fields: [resultId], references: [id], onDelete: Cascade)
  subjectId          String
  subject            Subject              @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  internalMarks      Float                @default(0.0)
  assignmentMarks    Float                @default(0.0)
  labMarks           Float                @default(0.0)
  practicalMarks     Float                @default(0.0)
  projectMarks       Float                @default(0.0)
  semesterExamMarks  Float                @default(0.0)
  graceMarks         Float                @default(0.0)
  moderationMarks    Float                @default(0.0)
  totalMarks         Float                @default(0.0)
  grade              String               @default("F")
  gradePoint         Float                @default(0.0)
  passFail           String               @default("FAIL") // PASS, FAIL
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  revaluationRequests RevaluationRequest[]

  @@unique([resultId, subjectId])
}

model GradeScheme {
  id             String          @id @default(uuid())
  academicYearId String
  academicYear   AcademicYear    @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
